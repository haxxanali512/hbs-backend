<div id="deleteChoiceModal" class="hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
  <div class="absolute inset-0 bg-black/40" data-delete-choice-backdrop></div>
  <div class="relative z-10 w-full max-w-md rounded-lg bg-white shadow-lg mx-4">
    <div class="px-5 py-4 border-b border-gray-200">
      <h3 id="deleteChoiceModalTitle" class="text-base font-semibold text-gray-900">Delete?</h3>
    </div>
    <div class="px-5 py-4 space-y-4">
      <p id="deleteChoiceModalPrompt" class="text-sm text-gray-700">Choose how to delete:</p>
      <div id="deleteChoiceModalRadios" class="space-y-3">
        <label class="flex items-start gap-3 cursor-pointer">
          <input type="radio" name="delete_choice_type" value="soft" class="mt-1 h-4 w-4 text-indigo-600 border-gray-300 focus:ring-indigo-500" data-delete-choice-radio="soft" checked>
          <div>
            <span class="text-sm font-medium text-gray-900">Discard from table</span>
            <p class="text-xs text-gray-500 mt-0.5">Remove from the list (soft delete). Data is preserved and can be restored.</p>
          </div>
        </label>
        <label class="flex items-start gap-3 cursor-pointer">
          <input type="radio" name="delete_choice_type" value="hard" class="mt-1 h-4 w-4 text-red-600 border-gray-300 focus:ring-red-500" data-delete-choice-radio="hard">
          <div>
            <span class="text-sm font-medium text-gray-900">Permanently delete</span>
            <p class="text-xs text-gray-500 mt-0.5">Permanently remove this record and related data. This cannot be undone.</p>
          </div>
        </label>
      </div>
      <div id="deleteChoiceModalRequireTextContainer" class="hidden pt-2 space-y-1">
        <label for="deleteChoiceModalRequireText" class="block text-xs font-medium text-gray-700">Type DELETE to confirm permanent deletion</label>
        <input type="text"
               id="deleteChoiceModalRequireText"
               class="w-full border border-gray-300 rounded-md px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-red-500"
               placeholder="DELETE"
               autocomplete="off" />
        <p id="deleteChoiceModalRequireTextError" class="text-xs text-red-600 hidden">You must type DELETE exactly to confirm.</p>
      </div>
    </div>
    <div class="px-5 pb-4 flex items-center justify-end gap-3">
      <button type="button" id="deleteChoiceModalCancel" class="rounded-md border border-gray-200 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Cancel</button>
      <button type="button" id="deleteChoiceModalConfirm" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-700">Delete</button>
    </div>
  </div>
</div>
<form id="deleteChoiceModalForm" action="#" method="post" class="hidden" data-turbo="false"></form>
