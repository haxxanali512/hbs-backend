<div class="relative">
  <details class="group">
    <summary class="list-none flex w-full cursor-pointer items-center justify-between rounded-md border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
      <span class="truncate"><%= current_portal_context.to_s.humanize %></span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
    </summary>
    <div class="mt-2 w-full rounded-md border border-gray-200 bg-white p-2 shadow-sm">
      <% portal_switcher_contexts.each do |context| %>
        <%= button_to switch_portal_context_path(context: context), method: :patch, data: { turbo: false }, class: "block w-full rounded-md px-3 py-2 text-left text-sm #{context == current_portal_context ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50'}" do %>
          <%= context.to_s.humanize %>
        <% end %>
      <% end %>
    </div>
  </details>
</div>
