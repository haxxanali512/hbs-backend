<div id="confirmModal" class="hidden fixed inset-0 z-50 items-center justify-center">
  <div class="absolute inset-0 bg-black/40"></div>
  <div class="relative z-10 w-full max-w-sm rounded-lg bg-white shadow-lg">
    <div class="px-5 py-4 border-b border-gray-200">
      <h3 class="text-base font-semibold text-gray-900">Are you sure?</h3>
    </div>
    <div class="px-5 py-4 text-sm text-gray-700" data-confirm-body-target>
      This action cannot be undone.
    </div>
    <div id="confirmModalInputContainer" class="px-5 pb-2 space-y-1 hidden">
      <label for="confirmModalInput" id="confirmModalInputLabel" class="block text-xs font-medium text-gray-700"></label>
      <input type="text"
             id="confirmModalInput"
             class="w-full border border-gray-300 rounded-md px-2 py-1 text-xs focus:outline-none focus:ring-2 focus:ring-red-500"
             autocomplete="off" />
      <p id="confirmModalInputError" class="text-xs text-red-600 hidden">Text does not match. Please type the required word exactly.</p>
    </div>
    <div class="px-5 pb-4 flex items-center justify-end gap-3">
      <button type="button" id="confirmModalCancel" class="rounded-md border border-gray-200 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50">Cancel</button>
      <button type="button" id="confirmModalConfirm" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-700">Confirm</button>
    </div>
    <%= form_with url: '#', method: :post, id: 'confirmModalForm', data: { turbo: false } do %>
    <% end %>
  </div>
</div>

<!-- JS moved to app/assets/javascripts/confirm_modal.js to work with CSP & Turbo -->

