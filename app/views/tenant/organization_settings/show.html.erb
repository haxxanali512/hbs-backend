<div class="min-h-screen bg-gray-50 py-8">
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Organization Settings</h1>
          <p class="mt-2 text-gray-600">Manage your organization's configuration</p>
        </div>
        <div>
          <%= link_to "Edit Settings", edit_tenant_organization_setting_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
        </div>
      </div>
    </div>

    <!-- Critical Resources Warning -->
    <% if @current_organization.activated? && @current_organization.has_missing_critical_resources? %>
      <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3 flex-1">
            <h3 class="text-sm font-medium text-yellow-800">
              Missing Critical Resources
            </h3>
            <div class="mt-2 text-sm text-yellow-700">
              <p>Your organization is missing the following critical resources:</p>
              <ul class="list-disc list-inside mt-2 space-y-1">
                <% @current_organization.missing_critical_resources.each do |resource| %>
                  <li><%= resource %></li>
                <% end %>
              </ul>
              <p class="mt-3">Please add these resources to enable full functionality.</p>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Time Zone -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Time Zone</h2>
      <p class="text-sm text-gray-700">
        <% tz = @organization_setting.effective_time_zone %>
        <%= ActiveSupport::TimeZone[tz]&.to_s || tz %>.
        All date and time fields use this time zone.
      </p>
    </div>

    <!-- Settings Display -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Medical Record Number (MRN) Settings</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700">MRN Enabled</label>
          <p class="mt-1 text-sm text-gray-900">
            <%= @organization_setting.mrn_enabled? ? "Yes" : "No" %>
          </p>
        </div>
        <% if @organization_setting.mrn_enabled? %>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700">MRN Prefix</label>
              <p class="mt-1 text-sm text-gray-900"><%= @organization_setting.mrn_prefix || "Not set" %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">MRN Sequence</label>
              <p class="mt-1 text-sm text-gray-900"><%= @organization_setting.mrn_sequence || "Not set" %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">MRN Format</label>
              <p class="mt-1 text-sm text-gray-900"><%= @organization_setting.mrn_format || "Not set" %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Billing & Payment Methods -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Billing & Payment Methods</h2>
      </div>

      <% billing = @organization_billing %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div>
          <label class="block text-sm font-medium text-gray-700">Current Provider</label>
          <p class="mt-1 text-sm text-gray-900"><%= billing.provider.present? ? billing.provider.humanize : "Not configured" %></p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">Billing Status</label>
          <p class="mt-1 text-sm text-gray-900"><%= billing.billing_status.present? ? billing.billing_status.humanize : "N/A" %></p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">Saved Card / Account</label>
          <p class="mt-1 text-sm text-gray-900">
            <% if billing.method_last4.present? %>
              **** <%= billing.method_last4 %>
            <% elsif billing.gocardless_customer_id.present? %>
              Direct Debit (GoCardless)
            <% else %>
              No payment method saved
            <% end %>
          </p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700">Note</label>
          <p class="mt-1 text-sm text-gray-500">Multiple payment methods are planned. Current schema supports one active primary method.</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <button type="button" id="open-settings-stripe-modal" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700">
          Add / Update Card (Stripe)
        </button>
        <button type="button" id="open-settings-gocardless-modal" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-md hover:bg-green-700">
          Add / Update Direct Debit (GoCardless)
        </button>
        <%= button_to "Request Manual Billing", update_billing_method_tenant_organization_setting_path(provider: "manual"), method: :patch, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50" %>
      </div>
    </div>

    <!-- Resource Status -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% summary = @current_organization.resource_status_summary %>
      
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Resource Status</h3>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-700">Providers</span>
            <div class="flex items-center space-x-2">
              <% if summary[:providers][:present] %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  <%= summary[:providers][:count] %> active
                </span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                  Missing
                </span>
              <% end %>
            </div>
          </div>

          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-700">Fee Schedules</span>
            <div class="flex items-center space-x-2">
              <% if summary[:fee_schedules][:present] %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  <%= summary[:fee_schedules][:count] %> active
                </span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                  Missing
                </span>
              <% end %>
            </div>
          </div>

          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-700">Specialties</span>
            <div class="flex items-center space-x-2">
              <% if summary[:specialties][:present] %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  <%= summary[:specialties][:count] %> active
                </span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                  Missing
                </span>
              <% end %>
            </div>
          </div>

          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-700">Locations</span>
            <div class="flex items-center space-x-2">
              <% if summary[:locations][:present] %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  <%= summary[:locations][:count] %> active
                </span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                  Missing
                </span>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Quick Actions</h3>
        <div class="space-y-2">
          <%= link_to "Add Provider", new_tenant_provider_path, class: "block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md transition-colors" unless summary[:providers][:present] %>
          <%= link_to "Create Fee Schedule", new_tenant_fee_schedule_path, class: "block w-full text-center bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-md transition-colors" unless summary[:fee_schedules][:present] %>
          <%= link_to "Add Location", new_tenant_organization_location_path, class: "block w-full text-center bg-purple-600 hover:bg-purple-700 text-white font-medium py-2 px-4 rounded-md transition-colors" unless summary[:locations][:present] %>
          <%= link_to "View Specialties", tenant_specialties_path, class: "block w-full text-center bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-md transition-colors" %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Stripe Card Setup Modal (Settings) -->
<div id="settings-stripe-modal" class="fixed inset-0 bg-gray-600 bg-opacity-0 overflow-y-auto h-full w-full hidden z-50 transition-all duration-300 ease-in-out">
  <div class="flex min-h-full items-center justify-center p-4">
    <div class="relative transform transition-all duration-300 ease-in-out scale-95 opacity-0 w-full max-w-md shadow-xl rounded-lg bg-white" id="settings-stripe-modal-content">
      <div class="p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold text-gray-900">Add / Update Card</h3>
          <button id="close-settings-stripe-modal" class="text-gray-400 hover:text-gray-600">&times;</button>
        </div>
        <form id="settings-card-form">
          <div id="settings-card-element" class="p-3 border border-gray-200 rounded-lg bg-white"></div>
          <div id="settings-card-errors" class="mt-2 text-sm text-red-600 hidden"></div>
          <div class="mt-5 flex items-center justify-end gap-3">
            <button type="button" id="cancel-settings-stripe-card" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">Cancel</button>
            <button type="submit" id="submit-settings-card" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700">Save Card</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- GoCardless Setup Modal (Settings) -->
<div id="settings-gocardless-modal" class="fixed inset-0 bg-gray-600 bg-opacity-0 overflow-y-auto h-full w-full hidden z-50 transition-all duration-300 ease-in-out">
  <div class="flex min-h-full items-center justify-center p-4">
    <div class="relative transform transition-all duration-300 ease-in-out scale-95 opacity-0 w-full max-w-2xl shadow-xl rounded-lg bg-white" id="settings-gocardless-modal-content">
      <div class="p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold text-gray-900">Set Up Direct Debit</h3>
          <button id="close-settings-gocardless-modal" class="text-gray-400 hover:text-gray-600">&times;</button>
        </div>
        <form id="settings-gocardless-form" class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="text" id="settings-gc-given-name" value="<%= current_user.first_name %>" class="w-full h-10 rounded-lg border border-gray-200 px-3 text-sm" placeholder="First Name" required>
            <input type="text" id="settings-gc-family-name" value="<%= current_user.last_name %>" class="w-full h-10 rounded-lg border border-gray-200 px-3 text-sm" placeholder="Last Name" required>
          </div>
          <input type="email" id="settings-gc-email" value="<%= current_user.email %>" class="w-full h-10 rounded-lg border border-gray-200 px-3 text-sm" placeholder="Email" required>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="text" id="settings-gc-address-line1" class="w-full h-10 rounded-lg border border-gray-200 px-3 text-sm" placeholder="Address Line 1" required>
            <input type="text" id="settings-gc-city" class="w-full h-10 rounded-lg border border-gray-200 px-3 text-sm" placeholder="City" required>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="text" id="settings-gc-postal-code" class="w-full h-10 rounded-lg border border-gray-200 px-3 text-sm" placeholder="Postal Code" required>
            <select id="settings-gc-country-code" class="w-full h-10 rounded-lg border border-gray-200 px-3 text-sm" required>
              <option value="GB">United Kingdom</option>
              <option value="US">United States</option>
              <option value="CA">Canada</option>
            </select>
          </div>
          <div id="settings-gc-errors" class="hidden text-sm text-red-600"></div>
          <div class="mt-5 flex items-center justify-end gap-3">
            <button type="button" id="cancel-settings-gocardless" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">Cancel</button>
            <button type="submit" id="submit-settings-gocardless" class="px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-md hover:bg-green-700">Set Up Direct Debit</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  function initializeOrganizationSettingsBilling() {
    if (window._organizationSettingsBillingInitialized) return;
    window._organizationSettingsBillingInitialized = true;

    const stripeModal = document.getElementById("settings-stripe-modal");
    const stripeModalContent = document.getElementById("settings-stripe-modal-content");
    const openStripe = document.getElementById("open-settings-stripe-modal");
    const closeStripe = document.getElementById("close-settings-stripe-modal");
    const cancelStripe = document.getElementById("cancel-settings-stripe-card");
    const stripeErrors = document.getElementById("settings-card-errors");

    const gcModal = document.getElementById("settings-gocardless-modal");
    const gcModalContent = document.getElementById("settings-gocardless-modal-content");
    const openGc = document.getElementById("open-settings-gocardless-modal");
    const closeGc = document.getElementById("close-settings-gocardless-modal");
    const cancelGc = document.getElementById("cancel-settings-gocardless");

    if (!stripeModal || !gcModal) return;

    let stripe, elements, cardElement;

    function openModal(modal, content) {
      modal.classList.remove("hidden");
      setTimeout(() => {
        modal.classList.remove("bg-opacity-0");
        modal.classList.add("bg-opacity-50");
        content.classList.remove("scale-95", "opacity-0");
        content.classList.add("scale-100", "opacity-100");
      }, 10);
    }

    function closeModal(modal, content) {
      modal.classList.remove("bg-opacity-50");
      modal.classList.add("bg-opacity-0");
      content.classList.remove("scale-100", "opacity-100");
      content.classList.add("scale-95", "opacity-0");
      setTimeout(() => modal.classList.add("hidden"), 300);
    }

    function initStripeForSettings() {
      if (stripe) return;
      if (typeof Stripe === "undefined") return;
      stripe = Stripe("<%= Rails.configuration.stripe[:publishable_key] %>");
      elements = stripe.elements();
      cardElement = elements.create("card");
      cardElement.mount("#settings-card-element");
      cardElement.on("change", function(event) {
        if (event.error) {
          stripeErrors.textContent = event.error.message;
          stripeErrors.classList.remove("hidden");
        } else {
          stripeErrors.classList.add("hidden");
        }
      });
    }

    openStripe?.addEventListener("click", function(e) {
      e.preventDefault();
      openModal(stripeModal, stripeModalContent);
      setTimeout(initStripeForSettings, 50);
    });
    closeStripe?.addEventListener("click", function(e) { e.preventDefault(); closeModal(stripeModal, stripeModalContent); });
    cancelStripe?.addEventListener("click", function(e) { e.preventDefault(); closeModal(stripeModal, stripeModalContent); });
    stripeModal?.addEventListener("click", function(e) { if (e.target === stripeModal) closeModal(stripeModal, stripeModalContent); });

    document.getElementById("settings-card-form")?.addEventListener("submit", async function(e) {
      e.preventDefault();
      const submitBtn = document.getElementById("submit-settings-card");
      submitBtn.disabled = true;
      try {
        const siResp = await fetch("/tenant/stripe/setup_intent", {
          method: "POST",
          headers: { "Content-Type": "application/json", "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content }
        });
        const siData = await siResp.json();
        if (!siData.success) throw new Error(siData.error || "Failed to create setup intent");
        const result = await stripe.confirmCardSetup(siData.client_secret, { payment_method: { card: cardElement } });
        if (result.error) throw new Error(result.error.message);

        const saveResp = await fetch("/tenant/stripe/confirm_card", {
          method: "POST",
          headers: { "Content-Type": "application/json", "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content },
          body: JSON.stringify({ payment_method_id: result.setupIntent.payment_method })
        });
        const saveData = await saveResp.json();
        if (!saveData.success) throw new Error(saveData.error || "Failed to save card");
        window.location.reload();
      } catch (err) {
        stripeErrors.textContent = err.message;
        stripeErrors.classList.remove("hidden");
      } finally {
        submitBtn.disabled = false;
      }
    });

    openGc?.addEventListener("click", function(e) { e.preventDefault(); openModal(gcModal, gcModalContent); });
    closeGc?.addEventListener("click", function(e) { e.preventDefault(); closeModal(gcModal, gcModalContent); });
    cancelGc?.addEventListener("click", function(e) { e.preventDefault(); closeModal(gcModal, gcModalContent); });
    gcModal?.addEventListener("click", function(e) { if (e.target === gcModal) closeModal(gcModal, gcModalContent); });

    document.getElementById("settings-gocardless-form")?.addEventListener("submit", async function(e) {
      e.preventDefault();
      const errorEl = document.getElementById("settings-gc-errors");
      const payload = {
        given_name: document.getElementById("settings-gc-given-name").value,
        family_name: document.getElementById("settings-gc-family-name").value,
        email: document.getElementById("settings-gc-email").value,
        address_line1: document.getElementById("settings-gc-address-line1").value,
        city: document.getElementById("settings-gc-city").value,
        postal_code: document.getElementById("settings-gc-postal-code").value,
        country_code: document.getElementById("settings-gc-country-code").value,
        context: "settings"
      };

      try {
        const resp = await fetch("/tenant/gocardless/create_redirect_flow", {
          method: "POST",
          headers: { "Content-Type": "application/json", "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content },
          body: JSON.stringify(payload)
        });
        const data = await resp.json();
        if (!data.success) throw new Error(data.error || "Failed to start authorization");
        window.location.href = data.redirect_url;
      } catch (err) {
        errorEl.textContent = err.message;
        errorEl.classList.remove("hidden");
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeOrganizationSettingsBilling);
  } else {
    initializeOrganizationSettingsBilling();
  }
  document.addEventListener("turbo:load", initializeOrganizationSettingsBilling);
</script>

