<div class="min-h-screen bg-gray-50 py-8">
  <div class="mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8">
    <h1 class="text-2xl font-bold text-gray-900">Business Information</h1>
    <p class="mt-1 text-sm text-gray-600">Step 1 of 4: provide the required organization intake details.</p>

    <%= form_with url: tenant_activation_compliance_path, method: :patch, scope: :intake, class: "mt-6 space-y-6" do |f| %>
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
          <div>
            <%= f.label :company_name, "Company Name", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :company_name, value: @organization.name, required: true, class: "mt-1 block w-full rounded-md border-gray-300 text-sm" %>
          </div>
          <div>
            <%= f.label :owner_name, "Owner Name", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :owner_name, value: [@owner.first_name, @owner.last_name].compact.join(" "), required: true, class: "mt-1 block w-full rounded-md border-gray-300 text-sm" %>
          </div>
          <div>
            <%= f.label :primary_email, "Primary Email", class: "block text-sm font-medium text-gray-700" %>
            <%= f.email_field :primary_email, value: @contact.email.presence || @owner.email, required: true, class: "mt-1 block w-full rounded-md border-gray-300 text-sm" %>
          </div>
          <div>
            <%= f.label :phone_number, "Phone Number", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :phone_number, value: @contact.phone, required: true, class: "mt-1 block w-full rounded-md border-gray-300 text-sm" %>
          </div>
          <div class="md:col-span-2">
            <%= f.label :business_address, "Business Address", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_area :business_address, value: @contact.address_line1, rows: 3, required: true, class: "mt-1 block w-full rounded-md border-gray-300 text-sm" %>
          </div>
          <div>
            <%= f.label :ein, "EIN (9 digits)", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :ein, value: @identifier.tax_identification_number, required: true, maxlength: 9, pattern: "\\d{9}", class: "mt-1 block w-full rounded-md border-gray-300 text-sm" %>
          </div>
          <div>
            <%= f.label :npi, "NPI (10 digits)", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :npi, value: @identifier.npi, required: true, maxlength: 10, pattern: "\\d{10}", class: "mt-1 block w-full rounded-md border-gray-300 text-sm" %>
          </div>
        </div>
      </div>

      <div class="flex justify-end">
        <%= f.submit "Continue to Contract", class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700" %>
      </div>
    <% end %>
  </div>
</div>
