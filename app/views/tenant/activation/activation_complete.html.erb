<div class="min-h-screen bg-gray-50">
  <div class="bg-white border-b border-gray-200">
    <div class="px-6 py-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <div>
            <h1 class="text-xl font-semibold text-gray-900">Activation Complete</h1>
            <p class="text-sm text-gray-500">Your organization is ready to go</p>
          </div>
        </div>
        <div class="flex items-center space-x-3">
          <div class="text-right">
            <p class="text-sm font-medium text-gray-900"><%= current_user.email %></p>
            <p class="text-xs text-gray-500">Account Manager</p>
          </div>
          <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center">
            <span class="text-white font-medium text-sm"><%= current_user.email.first.upcase %></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="w-full mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-2xl font-bold text-gray-900">Activation Finished</h2>
        <div class="flex items-center space-x-2 text-sm text-gray-500">
          <span>Step 4 of 4</span>
          <div class="w-16 h-1 bg-gray-200 rounded-full">
            <div class="w-16 h-1 bg-blue-600 rounded-full"></div>
          </div>
        </div>
      </div>
      <p class="text-gray-600">
        <% if @organization.activated? %>
          All required onboarding steps are complete and your account is now active.
        <% else %>
          All required onboarding steps are complete. Activate your organization to access the dashboard.
        <% end %>
      </p>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <div class="flex items-center justify-center">
        <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center">
          <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
      </div>

      <h3 class="mt-4 text-center text-xl font-semibold text-gray-900">Congratulations!</h3>
      <p class="mt-2 text-center text-sm text-gray-600">
        <% if @organization.activated? %>
          Your organization <span class="font-semibold text-gray-900"><%= @organization.name %></span> has been successfully activated.
        <% else %>
          Your organization <span class="font-semibold text-gray-900"><%= @organization.name %></span> is ready for final activation.
        <% end %>
      </p>

      <div class="mt-6">
        <h4 class="text-sm font-semibold text-gray-900">Completed Steps</h4>
        <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-2">
          <div class="flex items-center justify-between rounded-lg border border-gray-200 bg-gray-50 px-3 py-2">
            <span class="text-sm text-gray-700">1. Business Information</span>
            <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">Completed</span>
          </div>
          <div class="flex items-center justify-between rounded-lg border border-gray-200 bg-gray-50 px-3 py-2">
            <span class="text-sm text-gray-700">2. Contract & Tier</span>
            <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">Completed</span>
          </div>
          <div class="flex items-center justify-between rounded-lg border border-gray-200 bg-gray-50 px-3 py-2">
            <span class="text-sm text-gray-700">3. Onboarding Payment</span>
            <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">Completed</span>
          </div>
          <div class="flex items-center justify-between rounded-lg border border-gray-200 bg-gray-50 px-3 py-2">
            <span class="text-sm text-gray-700">4. Activation Ready</span>
            <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">Completed</span>
          </div>
        </div>
      </div>

      <div class="mt-6 flex justify-center">
        <% if @organization.activated? %>
          <%= link_to "View Dashboard", tenant_dashboard_path, class: "inline-flex items-center rounded-md bg-blue-600 px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
        <% else %>
          <%= button_to "Activate Organization", tenant_activation_activate_path, method: :post, class: "inline-flex items-center rounded-md bg-green-600 px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
        <% end %>
      </div>
    </div>

    <div class="mt-6 bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <h4 class="text-sm font-semibold text-gray-900">What's Next</h4>
      <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-3">
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3 text-sm text-gray-700">
          Access your dashboard with all enabled features.
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3 text-sm text-gray-700">
          Invite additional team members when needed.
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3 text-sm text-gray-700">
          Continue setup and start using platform services.
        </div>
      </div>
    </div>
  </div>
</div>
