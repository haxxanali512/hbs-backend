<div class="min-h-screen bg-gray-50 py-8">
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Encounter Details</h1>
          <p class="mt-2 text-gray-600">View and manage encounter information</p>
        </div>
        <div class="flex space-x-3">
          <%= link_to "Back to Encounters", tenant_encounters_path, class: "bg-gray-600 hover:bg-gray-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
          <%= link_to "Edit", edit_tenant_encounter_path(@encounter), class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" if !@encounter.cascaded? %>
        </div>
      </div>
    </div>

    <!-- Status Actions -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-4">
          <span class="text-sm font-medium text-gray-700">Current Status:</span>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= @encounter.tenant_visible_status_badge_color %>">
            <%= @encounter.tenant_visible_status_label %>
          </span>
          <% if @encounter.cascaded? %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-purple-100 text-purple-800">
              Cascaded
            </span>
          <% end %>
        </div>

        <div class="flex space-x-2">
          <% if @encounter.ready_for_review? && @encounter.may_mark_reviewed? %>
            <%= button_to "Mark as Reviewed", mark_reviewed_tenant_encounter_path(@encounter),
                method: :post,
                form: { class: "inline-block" },
                class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors",
                data: { turbo_confirm: "Mark this encounter as reviewed?" } %>
          <% end %>
          
          <% if @encounter.reviewed? && @encounter.may_mark_ready_to_submit? %>
            <%= button_to "Mark Ready to Submit", mark_ready_to_submit_tenant_encounter_path(@encounter),
                method: :post,
                form: { class: "inline-block" },
                class: "bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-lg transition-colors",
                data: { turbo_confirm: "Mark this encounter as ready to submit to billing?" } %>
          <% end %>
          
          <% if current_user.permissions_for("tenant", "encounters", "submit_for_billing") && @encounter.organization.organization_setting&.ezclaim_enabled? %>
            <button type="button" 
                    onclick="openEzclaimModal('encounterBillingModal', '<%= billing_data_tenant_encounter_path(@encounter) %>', 'claim')"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-lg transition-colors">
              Submit for Billing
            </button>
          <% end %>
          
          <% if @encounter.may_cancel? %>
            <%= link_to "Cancel", cancel_tenant_encounter_path(@encounter), method: :post,
                class: "bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg transition-colors",
                data: { confirm: "Are you sure you want to cancel this encounter?" } %>
          <% end %>

          <% if current_user.permissions_for("tenant", "encounters", "destroy") %>
            <% if @encounter.internal_status_billed? %>
              <%= link_to "Request Claim Void", new_tenant_support_ticket_path(
                    void_request: "1",
                    support_ticket: {
                      category: "claims_issue",
                      sub_category: "other",
                      subject: "Claim Void Request — #{@encounter.patient&.full_name} — DOS #{@encounter.date_of_service&.strftime("%m/%d/%Y")} — #{current_organization&.name}",
                      description: "Please void this billed claim/encounter.\n\nEncounter ID: #{@encounter.id}\nPatient: #{@encounter.patient&.full_name}\nDOS: #{@encounter.date_of_service&.strftime("%m/%d/%Y")}\nProvider: #{@encounter.provider&.full_name}\nOrganization: #{current_organization&.name}\n\nReason: (please describe why this should be voided)\n",
                      linked_resource_type: "Encounter",
                      linked_resource_id: @encounter.id
                    }
                  ),
                  class: "bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
            <% else %>
              <% soft_url = tenant_encounter_path(@encounter) %>
              <% hard_allowed = (!@encounter.cascaded? && !@encounter.has_billing_document? && @encounter.internal_status.to_s == "pending") %>
              <% hard_url = (hard_allowed && (current_user.permissions_for("tenant", "encounters", "hard_destroy") || current_user.permissions_for("tenant", "encounters", "destroy"))) ? hard_destroy_tenant_encounter_path(@encounter) : nil %>
              <% message =
                   if @encounter.internal_status.to_s == "queued_for_billing" || @encounter.tenant_status.to_s == "in_process"
                     "<strong>Warning:</strong> This encounter has already been sent for billing. Deleting it may affect claim processing."
                   else
                     "Delete this encounter?"
                   end %>

              <a href="#"
                 class="bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg transition-colors"
                 data-delete-choice
                 data-delete-choice-title="Delete encounter?"
                 data-delete-choice-message="<%= message %>"
                 data-delete-choice-confirm-label="Delete"
                 data-delete-choice-soft-url="<%= soft_url %>"
                 <% if hard_url.present? %>data-delete-choice-hard-url="<%= hard_url %>"<% end %>>
                Delete
              </a>
            <% end %>
          <% end %>
          
          <% if @encounter.cascaded? %>
            <%= button_to "Request Correction", request_correction_tenant_encounter_path(@encounter),
                method: :post,
                form: { class: "inline-block" },
                class: "bg-orange-600 hover:bg-orange-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Encounter Information -->
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Encounter Information</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700">Patient</label>
              <p class="mt-1 text-sm text-gray-900"><%= @encounter.patient.full_name %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Provider</label>
              <p class="mt-1 text-sm text-gray-900"><%= @encounter.provider.full_name %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Date of Service</label>
              <p class="mt-1 text-sm text-gray-900"><%= @encounter.date_of_service.strftime("%B %d, %Y") %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Specialty</label>
              <p class="mt-1 text-sm text-gray-900"><%= @encounter.specialty.name %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Billing Channel</label>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @encounter.insurance? ? 'bg-blue-100 text-blue-800' : 'bg-green-100 text-green-800' %>">
                <%= @encounter.billing_channel&.humanize || "N/A" %>
              </span>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Status</label>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @encounter.tenant_visible_status_badge_color %>">
                <%= @encounter.tenant_visible_status_label %>
              </span>
            </div>
          </div>
        </div>

        <!-- Diagnosis Codes -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Diagnosis Codes</h2>
          <% if @encounter.diagnosis_codes.any? %>
            <div class="space-y-2">
              <% @encounter.diagnosis_codes.each do |diagnosis| %>
                <div class="flex items-center space-x-2">
                  <span class="text-sm font-mono text-blue-600"><%= diagnosis.code %></span>
                  <span class="text-sm text-gray-700">-</span>
                  <span class="text-sm text-gray-700"><%= diagnosis.description %></span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500">No diagnosis codes assigned</p>
          <% end %>
        </div>

        <!-- Notes -->
        <% if @encounter.notes.present? %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Clinical Notes</h2>
            <p class="text-sm text-gray-900 whitespace-pre-wrap"><%= @encounter.notes %></p>
          </div>
        <% end %>

        <!-- Files & Attachments -->
        <%= render "shared/encounter_summary_files", namespace: "tenant" %>

        <!-- Provider Notes Section -->
        <%= render "shared/provider_notes", namespace: "tenant" %>

        <!-- Comments Section -->
        <% if @encounter.encounter_comments.shared_with_client.where(redacted: false).exists? %>
          <%= render "shared/encounter_comments", namespace: "tenant" %>
        <% end %>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Status Information -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Information</h3>
          <div class="space-y-3">
            <div>
              <label class="block text-sm font-medium text-gray-700">Created</label>
              <p class="text-sm text-gray-900"><%= format_in_organization_tz(@encounter.created_at) %></p>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700">Last Updated</label>
              <p class="text-sm text-gray-900"><%= format_in_organization_tz(@encounter.updated_at) %></p>
            </div>

            <% if @encounter.prescription.present? %>
              <div>
                <label class="block text-sm font-medium text-gray-700">Prescription</label>
                <p class="text-sm text-gray-900">
                  <%= link_to @encounter.prescription.title, tenant_prescription_path(@encounter.prescription), class: "text-blue-600 hover:text-blue-800" %>
                </p>
              </div>
            <% end %>
            
            <% if @encounter.cascaded? %>
              <div>
                <label class="block text-sm font-medium text-gray-700">Cascaded At</label>
                <p class="text-sm text-gray-900"><%= format_in_organization_tz(@encounter.cascaded_at) %></p>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700">Display Status</label>
                <p class="text-sm text-gray-900"><%= @encounter.display_status_text %></p>
              </div>
            <% end %>

            <div>
              <div class="flex items-center justify-between gap-2">
                <label class="block text-sm font-medium text-gray-700">Clinical Documentation</label>
                <button type="button"
                        onclick="document.getElementById('attach_clinical_doc_modal').classList.remove('hidden'); document.body.style.overflow='hidden';"
                        class="text-xs font-medium text-blue-600 hover:text-blue-800 whitespace-nowrap">
                  + Add document
                </button>
              </div>
              <% if @encounter.clinical_documentations.with_file.any? %>
                <ul class="mt-1 space-y-1.5 text-sm text-gray-900">
                  <% @encounter.clinical_documentations.with_file.each do |doc| %>
                    <li class="flex items-center justify-between gap-2">
                      <span class="truncate"><%= doc.file.filename %></span>
                      <%= link_to "View", rails_blob_path(doc.file), target: "_blank", rel: "noopener", class: "text-xs text-blue-600 hover:text-blue-800 whitespace-nowrap" %>
                    </li>
                  <% end %>
                </ul>
              <% else %>
                <p class="mt-1 text-sm text-gray-500">No clinical documents yet.</p>
              <% end %>
            </div>
          </div>
        </div>

        <% if @encounter.cascaded? && @encounter.claim.present? && (@encounter.claim.submitted? || @encounter.claim.accepted? || @encounter.claim.denied?) %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Upload Documentation (Post-Submission)</h3>
            <%= form_with url: attach_document_tenant_encounter_path(@encounter), method: :post, local: true, multipart: true, class: "space-y-4" do |f| %>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                <%= text_field_tag 'document[title]', nil, class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500", placeholder: "e.g. PA Approval, Clinical Notes" %>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Document Type</label>
                <%= select_tag 'document[document_type]', options_for_select([['Supporting Document','supporting'],['Authorization','authorization'],['Clinical Notes','clinical_notes']]), include_blank: 'Select type', class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
              </div>

              <%= render "shared/document_upload",
                  document_type: "supporting",
                  field_name: "document[files]",
                  label: "File(s)",
                  hint: "PDF, images, or office docs. Max 25MB per file." %>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Description (optional)</label>
                <%= text_area_tag 'document[description]', nil, rows: 3, class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
              </div>

              <div class="flex justify-end">
                <%= f.submit "Upload", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div id="attach_clinical_doc_modal" class="hidden fixed inset-0 z-50 overflow-y-auto" aria-labelledby="attach_clinical_doc_modal_title" role="dialog" aria-modal="true">
  <div class="flex min-h-full items-center justify-center p-4">
    <div id="attach_clinical_doc_modal_backdrop" class="fixed inset-0 bg-black/40 transition-opacity" onclick="document.getElementById('attach_clinical_doc_modal').classList.add('hidden'); document.body.style.overflow='';"></div>
    <div class="relative z-10 w-full max-w-md rounded-lg bg-white shadow-xl p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 id="attach_clinical_doc_modal_title" class="text-lg font-semibold text-gray-900">Add clinical document(s)</h3>
        <button type="button" onclick="document.getElementById('attach_clinical_doc_modal').classList.add('hidden'); document.body.style.overflow='';" class="text-gray-400 hover:text-gray-600 rounded p-1">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <%= form_with url: attach_clinical_document_tenant_encounter_path(@encounter), method: :post, local: true, multipart: true, class: "space-y-4" do |f| %>
        <%= render "shared/document_upload",
            document_type: "clinical_documentation",
            field_name: "clinical_document[files]",
            label: "Clinical document(s)",
            hint: "PDF or images (JPEG, PNG, GIF, WebP). Max 25MB per file." %>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" onclick="document.getElementById('attach_clinical_doc_modal').classList.add('hidden'); document.body.style.overflow='';" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">Cancel</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700">Upload</button>
        </div>
      <% end %>
    </div>
  </div>
</div>
<script>
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var m = document.getElementById('attach_clinical_doc_modal');
      if (m && !m.classList.contains('hidden')) { m.classList.add('hidden'); document.body.style.overflow = ''; }
    }
  });
</script>

<%= render 'shared/ezclaim_modal',
    modal_id: 'encounterBillingModal',
    claim_id: @encounter.id,
    data_url: billing_data_tenant_encounter_path(@encounter),
    submit_url: submit_for_billing_tenant_encounter_path(@encounter),
    search_url: procedure_codes_search_tenant_encounter_path(@encounter),
    diagnosis_search_url: diagnosis_codes_search_tenant_encounter_path(@encounter),
    title: 'Submit for Billing',
    modal_type: 'claim'
%>

