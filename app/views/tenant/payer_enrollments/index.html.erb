<div class="min-h-screen bg-gray-50 py-8">
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Payer Enrollments</h1>
          <p class="mt-2 text-gray-600">Track your organization's payer enrollment records</p>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <%
      @status_options = @status_options || PayerEnrollment.statuses.keys
      @use_status_for_action_type = true
      @custom_selects = [
        { param: :payer_id, label: "Payer", options: [["All Payers", ""]] + Array(@payers).map { |p| [p.name, p.id] } },
        { param: :enrollment_type, label: "Type", options: [["All Types", ""]] + PayerEnrollment.enrollment_types.keys.map { |k| [k.humanize, k] } }
      ]
    %>
    <%= render "shared/filters" %>

    <!-- Enrollments Table -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Payer</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Provider</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Location</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">External ID</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Submitted</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Approved</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% if @payer_enrollments.any? %>
              <% @payer_enrollments.each do |enrollment| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 text-sm text-gray-900"><%= enrollment.payer.name %></td>
                  <td class="px-6 py-4 text-sm text-gray-900"><%= enrollment.enrollment_type.humanize %></td>
                  <td class="px-6 py-4 text-sm">
                    <span class="px-2 py-1 text-xs font-medium rounded-full <%= enrollment.status_badge_class %>">
                      <%= enrollment.status.humanize %>
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-900"><%= enrollment.provider&.full_name || '—' %></td>
                  <td class="px-6 py-4 text-sm text-gray-900"><%= enrollment.organization_location&.name || '—' %></td>
                  <td class="px-6 py-4 text-sm text-gray-900 font-mono"><%= enrollment.external_enrollment_id || '—' %></td>
                  <td class="px-6 py-4 text-sm text-gray-500"><%= enrollment.submitted_at.present? ? format_in_organization_tz(enrollment.submitted_at, "%m/%d/%Y") : '—' %></td>
                  <td class="px-6 py-4 text-sm text-gray-500"><%= enrollment.approved_at.present? ? format_in_organization_tz(enrollment.approved_at, "%m/%d/%Y") : '—' %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="8" class="px-6 py-4 text-center text-sm text-gray-500">No enrollments found</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <% if @pagy %>
      <div class="mt-6 flex items-center justify-between">
        <div class="text-sm text-gray-700">
          <%== pagination_info(@pagy) %>
        </div>
        <div>
          <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
        </div>
      </div>
    <% end %>
  </div>
</div>

