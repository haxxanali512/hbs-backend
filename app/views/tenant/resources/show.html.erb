<div class="min-h-screen bg-gray-50 py-8">
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
    <div class="mb-6 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900"><%= @resource.title %></h1>
        <div class="mt-2 flex items-center space-x-3 text-sm text-gray-500">
          <% if @resource.resource_type.present? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700">
              <%= @resource.resource_type.titleize %>
            </span>
          <% end %>
          <% if @resource.featured? %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
              Featured
            </span>
          <% end %>
        </div>
      </div>
      <div>
        <%= link_to "Back to Resources", tenant_resources_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 space-y-6">
      <% if @resource.description.present? %>
        <div>
          <p class="text-gray-800 whitespace-pre-line"><%= @resource.description %></p>
        </div>
      <% end %>

      <div>
        <h2 class="text-sm font-semibold text-gray-700 mb-2">Access</h2>
        <% if @resource.url.present? %>
          <p class="text-sm">
            <%= link_to "Open external link", @resource.url, target: "_blank", rel: "noopener", class: "text-indigo-600 hover:text-indigo-800" %>
          </p>
        <% end %>
        <% if @resource.file.attached? %>
          <p class="mt-1 text-sm">
            <%= link_to "Open attached file",
                        rails_blob_path(@resource.file, disposition: "inline"),
                        target: "_blank",
                        class: "text-indigo-600 hover:text-indigo-800" %>
          </p>
        <% end %>
        <% if @resource.url.blank? && !@resource.file.attached? %>
          <p class="text-sm text-gray-400">No link or file is attached to this resource.</p>
        <% end %>
      </div>

      <% if @resource.tag_list.any? %>
        <div>
          <h2 class="text-sm font-semibold text-gray-700 mb-2">Tags</h2>
          <div class="flex flex-wrap gap-1">
            <% @resource.tag_list.each do |tag| %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
                <%= tag %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

