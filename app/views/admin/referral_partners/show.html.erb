<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @referral_partner.full_name %></h1>
      <p class="mt-2 text-gray-600">Referral partner profile and performance.</p>
    </div>
    <div class="flex gap-3">
      <%= link_to "Edit", edit_admin_referral_partner_path(@referral_partner), class: "inline-flex items-center rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      <% unless @referral_partner.suspended? %>
        <%= button_to "Suspend", suspend_admin_referral_partner_path(@referral_partner), method: :patch, class: "inline-flex items-center rounded-lg border border-red-200 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-50" %>
      <% end %>
    </div>
  </div>
  <div class="grid gap-4 md:grid-cols-4">
    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm"><div class="text-sm text-gray-500">Referral Code</div><div class="mt-2 text-lg font-semibold text-gray-900"><%= @referral_partner.referral_code.presence || "—" %></div></div>
    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm"><div class="text-sm text-gray-500">Status</div><div class="mt-2 text-lg font-semibold text-gray-900"><%= @referral_partner.status.humanize %></div></div>
    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm"><div class="text-sm text-gray-500">Total Referrals</div><div class="mt-2 text-lg font-semibold text-gray-900"><%= @referral_partner.referral_relationships.count %></div></div>
    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm"><div class="text-sm text-gray-500">Lifetime Commissions</div><div class="mt-2 text-lg font-semibold text-gray-900">$<%= @referral_partner.referral_commissions.sum(:commission_amount) %></div></div>
  </div>
</div>
