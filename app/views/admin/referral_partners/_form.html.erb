<%= form_with model: [ :admin, @referral_partner ], class: "space-y-6", data: { turbo: false } do |f| %>
  <% if @referral_partner.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(@referral_partner.errors.count, "error") %> prohibited this referral partner from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% @referral_partner.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Partner Information</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-700">Existing User</label>
        <div class="relative referral-user-search">
          <input type="text"
                 id="referralPartnerUserSearch"
                 class="mt-2 block w-full h-11 rounded-lg border border-gray-200 bg-white px-4 pr-10 text-sm placeholder-gray-400 shadow-sm focus:border-blue-500 focus:ring-blue-500"
                 placeholder="Type to search users by name or email..."
                 autocomplete="off"
                 data-search-users-url="<%= url_for(controller: "/admin/referral_partners", action: :search_users) %>">
          <div class="absolute inset-y-0 right-0 top-2 flex items-center pr-3 pointer-events-none">
            <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m1.85-5.15a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <div id="referralPartnerUserSearchResults"
               class="hidden absolute z-50 w-full mt-1 bg-white border border-gray-200 rounded-md shadow-lg max-h-64 overflow-y-auto text-sm"></div>
        </div>
        <p id="referral-existing-user-hint" class="mt-1 text-xs text-gray-500">Select an existing user to auto-fill their details, or enter a new partner manually below.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700">First Name</label>
        <%= f.text_field :first_name, placeholder: "First name", class: "mt-2 block w-full h-11 rounded-lg border border-gray-200 bg-white px-4 text-sm placeholder-gray-400 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Last Name</label>
        <%= f.text_field :last_name, placeholder: "Last name", class: "mt-2 block w-full h-11 rounded-lg border border-gray-200 bg-white px-4 text-sm placeholder-gray-400 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Email</label>
        <%= f.email_field :email,
          placeholder: "partner@example.com",
          class: "mt-2 block w-full h-11 rounded-lg border border-gray-200 bg-white px-4 text-sm placeholder-gray-400 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Phone</label>
        <%= f.telephone_field :phone, placeholder: "(555) 123-4567", class: "mt-2 block w-full h-11 rounded-lg border border-gray-200 bg-white px-4 text-sm placeholder-gray-400 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Partner Type</label>
        <%= f.select :partner_type, ReferralPartner.partner_types.keys.map { |key| [key.humanize, key] }, { prompt: "Select partner type" }, class: "mt-2 block w-full h-11 rounded-lg border border-gray-200 bg-white px-4 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Status</label>
        <%= f.select :status, ReferralPartner.statuses.keys.map { |key| [key.humanize, key] }, { prompt: "Select status" }, class: "mt-2 block w-full h-11 rounded-lg border border-gray-200 bg-white px-4 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Linked Client</label>
        <%= f.collection_select :linked_client_id, Organization.order(:name), :id, :name, { include_blank: "None" }, class: "mt-2 block w-full h-11 rounded-lg border border-gray-200 bg-white px-4 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Tax Form Status</label>
        <%= f.text_field :tax_form_status, placeholder: "Pending, received, approved...", class: "mt-2 block w-full h-11 rounded-lg border border-gray-200 bg-white px-4 text-sm placeholder-gray-400 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
    </div>

    <div class="mt-6">
      <label class="block text-sm font-medium text-gray-700">Notes</label>
      <%= f.text_area :notes, rows: 4, placeholder: "Internal notes about this partner", class: "mt-2 block w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm placeholder-gray-400 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
    <div class="mt-6 flex items-center justify-end gap-4">
      <%= link_to "Cancel", admin_referral_partners_path, class: "text-sm text-gray-700 hover:text-gray-900" %>
      <%= f.submit(@referral_partner.persisted? ? "Update Partner" : "Create Partner", class: "inline-flex items-center rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-blue-700") %>
    </div>
  </div>
<% end %>

<script>
  function initializeReferralPartnerUserLookup() {
    const searchInput = document.getElementById("referralPartnerUserSearch");
    if (!searchInput || searchInput.dataset.lookupInitialized === "1") return;

    searchInput.dataset.lookupInitialized = "1";

    const form = searchInput.closest("form");
    if (!form) return;

    const firstNameInput = form.querySelector("#referral_partner_first_name");
    const lastNameInput = form.querySelector("#referral_partner_last_name");
    const emailInput = form.querySelector("#referral_partner_email");
    const linkedClientInput = form.querySelector("#referral_partner_linked_client_id");
    const results = document.getElementById("referralPartnerUserSearchResults");
    const hint = form.querySelector("#referral-existing-user-hint");
    const searchUrl = searchInput.dataset.searchUsersUrl;
    let timeoutId = null;

    const showHint = (message, className) => {
      if (!hint) return;
      hint.textContent = message;
      hint.classList.remove("text-emerald-600", "text-gray-500", "text-amber-600");
      hint.classList.add(className);
    };

    const hideResults = () => {
      if (!results) return;
      results.classList.add("hidden");
      results.innerHTML = "";
    };

    const renderResults = (users) => {
      if (!results) return;

      if (!users || users.length === 0) {
        results.innerHTML = '<div class="p-3 text-xs text-gray-500 text-center">No users found</div>';
        results.classList.remove("hidden");
        return;
      }

      results.innerHTML = users.map((user) => {
        const safeName = `${user.display_name || ""}`.replace(/"/g, "&quot;");
        const safeEmail = `${user.email || ""}`.replace(/"/g, "&quot;");
        const safeFirst = `${user.first_name || ""}`.replace(/"/g, "&quot;");
        const safeLast = `${user.last_name || ""}`.replace(/"/g, "&quot;");
        const safeLinkedClientId = `${user.linked_client_id || ""}`.replace(/"/g, "&quot;");
        const safeLinkedClientName = `${user.linked_client_name || ""}`.replace(/"/g, "&quot;");
        const badge = user.discarded ? '<span class="text-[10px] text-amber-600">(Archived)</span>' : "";

        return `
          <button type="button"
                  class="block w-full border-b border-gray-200 last:border-b-0 px-3 py-3 text-left hover:bg-blue-50 transition-colors"
                  data-user-display-name="${safeName}"
                  data-user-email="${safeEmail}"
                  data-user-first-name="${safeFirst}"
                  data-user-last-name="${safeLast}"
                  data-user-linked-client-id="${safeLinkedClientId}"
                  data-user-linked-client-name="${safeLinkedClientName}"
                  data-user-discarded="${user.discarded}">
            <div class="text-xs font-medium text-gray-900">${safeName} ${badge}</div>
            <div class="text-[11px] text-gray-500 mt-0.5">${safeEmail}</div>
            ${safeLinkedClientName ? `<div class="text-[11px] text-gray-400 mt-0.5">Org: ${safeLinkedClientName}</div>` : ""}
          </button>
        `;
      }).join("");

      results.classList.remove("hidden");
    };

    const applyUser = (button) => {
      if (!button) return;

      if (firstNameInput) firstNameInput.value = button.dataset.userFirstName || "";
      if (lastNameInput) lastNameInput.value = button.dataset.userLastName || "";
      if (emailInput) emailInput.value = button.dataset.userEmail || "";
      if (linkedClientInput && button.dataset.userLinkedClientId) {
        linkedClientInput.value = button.dataset.userLinkedClientId;
      }
      searchInput.value = button.dataset.userDisplayName || button.dataset.userEmail || "";

      const hintClass = button.dataset.userDiscarded === "true" ? "text-amber-600" : "text-emerald-600";
      const hintMessage = button.dataset.userDiscarded === "true"
        ? `Archived user selected: ${button.dataset.userDisplayName}. Details${button.dataset.userLinkedClientName ? ` and ${button.dataset.userLinkedClientName}` : ""} were filled.`
        : `Existing user selected: ${button.dataset.userDisplayName}. Details${button.dataset.userLinkedClientName ? ` and ${button.dataset.userLinkedClientName}` : ""} were filled.`;
      showHint(hintMessage, hintClass);
      hideResults();
    };

    searchInput.addEventListener("input", () => {
      const query = searchInput.value.trim();
      showHint("Select an existing user to auto-fill their details, or enter a new partner manually below.", "text-gray-500");

      if (timeoutId) clearTimeout(timeoutId);
      if (!query || !searchUrl) {
        hideResults();
        return;
      }

      timeoutId = setTimeout(async () => {
        try {
          const response = await fetch(`${searchUrl}?q=${encodeURIComponent(query)}`, {
            headers: { "Accept": "application/json" },
            credentials: "same-origin"
          });

          if (!response.ok) {
            hideResults();
            return;
          }

          const users = await response.json();
          renderResults(users);
        } catch (_error) {
          hideResults();
        }
      }, 200);
    });

    searchInput.addEventListener("focus", () => {
      if (searchInput.value.trim().length > 0) {
        searchInput.dispatchEvent(new Event("input"));
      }
    });

    if (results) {
      results.addEventListener("click", (event) => {
        const button = event.target.closest("button[data-user-email]");
        if (!button) return;
        applyUser(button);
      });
    }

    document.addEventListener("click", (event) => {
      const wrapper = document.querySelector(".referral-user-search");
      if (wrapper && !wrapper.contains(event.target)) {
        hideResults();
      }
    });
  }

  document.addEventListener("DOMContentLoaded", initializeReferralPartnerUserLookup);
  document.addEventListener("turbo:load", initializeReferralPartnerUserLookup);
</script>
