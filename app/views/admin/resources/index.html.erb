<div class="min-h-screen bg-gray-50 py-8">
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">Resources</h1>
        <p class="mt-2 text-gray-600">Evergreen content for tenants (articles, videos, guides).</p>
      </div>
      <div>
        <%= link_to "New Resource", new_admin_resource_path,
            class: "inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-md" %>
      </div>
    </div>

    <% 
      @search_placeholder = "Title, description, tags..."
    %>
    <%= render "shared/filters" %>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Featured</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @resources.each do |resource| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900">
                    <%= link_to resource.title, admin_resource_path(resource), class: "text-indigo-600 hover:text-indigo-800" %>
                  </div>
                  <% if resource.description.present? %>
                    <div class="text-xs text-gray-500 truncate max-w-xs">
                      <%= resource.description %>
                    </div>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= resource.resource_type&.titleize || "—" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <% status_classes = resource.published? ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-800" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_classes %>">
                    <%= resource.status.humanize %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <% if resource.featured? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                      Featured
                    </span>
                  <% else %>
                    <span class="text-xs text-gray-400">—</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= resource.created_at.strftime("%b %d, %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-2">
                    <%= link_to "View", admin_resource_path(resource), class: "text-blue-600 hover:text-blue-800" %>
                    <%= link_to "Edit", edit_admin_resource_path(resource), class: "text-indigo-600 hover:text-indigo-800" %>
                    <%= link_to "Delete", admin_resource_path(resource),
                        method: :delete,
                        class: "text-red-600 hover:text-red-800",
                        data: { confirm: "Are you sure you want to delete this resource?" } %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @resources.empty? %>
        <div class="text-center py-12">
          <div class="text-gray-500 text-lg">No resources found</div>
          <div class="text-gray-400 text-sm mt-2">Try adjusting your filters or create a new resource.</div>
        </div>
      <% end %>
    </div>

    <% if @pagy %>
      <div class="mt-6 flex items-center justify-between">
        <div class="text-sm text-gray-700">
          <%= pagination_info(@pagy) %>
        </div>
        <div>
          <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
        </div>
      </div>
    <% end %>
  </div>
</div>

