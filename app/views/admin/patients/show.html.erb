<div class="min-h-screen bg-gray-50 py-8">
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-3xl font-bold text-gray-900"><%= @patient.full_name %></h1>
          <p class="mt-2 text-gray-600">Patient Details - <%= @patient.organization.name %></p>
        </div>
        <div class="flex space-x-3">
          <%= link_to "Back to Patients", admin_patients_path, class: "bg-gray-600 hover:bg-gray-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
          <%= link_to "Edit", edit_admin_patient_path(@patient), class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
        </div>
      </div>
    </div>

    <!-- Status Actions -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-4">
          <span class="text-sm font-medium text-gray-700">Organization:</span>
          <span class="text-sm font-semibold text-gray-900"><%= @patient.organization.name %></span>
          <span class="text-sm font-medium text-gray-700 ml-4">Status:</span>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= @patient.status_badge_color %>">
            <%= @patient.status.humanize %>
          </span>
        </div>

        <div class="flex space-x-2">
          <% if @patient.inactive? %>
            <%= link_to "Activate", activate_admin_patient_path(@patient), method: :post,
                class: "bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
            <%= link_to "Reactivate", reactivate_admin_patient_path(@patient), method: :post,
                class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
          <% end %>
          
          <% if @patient.active? %>
            <%= link_to "Inactivate", inactivate_admin_patient_path(@patient), method: :post,
                class: "bg-yellow-600 hover:bg-yellow-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
          <% end %>
          
          <% unless @patient.is_deceased? %>
            <%= link_to "Mark Deceased", mark_deceased_admin_patient_path(@patient), method: :post,
                class: "bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg transition-colors",
                data: { confirm: "This action is irreversible. Continue?" } %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Patient Information -->
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Personal Information</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700">First Name</label>
              <p class="mt-1 text-sm text-gray-900"><%= @patient.first_name %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Last Name</label>
              <p class="mt-1 text-sm text-gray-900"><%= @patient.last_name %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Date of Birth</label>
              <p class="mt-1 text-sm text-gray-900"><%= @patient.formatted_dob || "Not provided" %></p>
              <% if @patient.age.present? %>
                <p class="text-sm text-gray-500">Age: <%= @patient.age %> years</p>
              <% end %>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Sex at Birth</label>
              <p class="mt-1 text-sm text-gray-900"><%= @patient.sex_at_birth || "Not provided" %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">MRN</label>
              <p class="mt-1 text-sm text-gray-900"><%= @patient.mrn || "-" %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">External ID</label>
              <p class="mt-1 text-sm text-gray-900"><%= @patient.external_id || "-" %></p>
            </div>
          </div>
        </div>

        <!-- Contact Information -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Contact Information</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700">Email</label>
              <p class="mt-1 text-sm text-gray-900"><%= @patient.email || "Not provided" %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Phone</label>
              <p class="mt-1 text-sm text-gray-900"><%= @patient.phone_number || "Not provided" %></p>
            </div>
          </div>
        </div>

        <!-- Address -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Address</h2>
          <div>
            <label class="block text-sm font-medium text-gray-700">Address</label>
            <p class="mt-1 text-sm text-gray-900">
              <%= @patient.full_address || "Not provided" %>
            </p>
          </div>
        </div>

        <!-- Visit Count by Year and Service Type -->
        <% 
          visit_counts = @patient.visit_count_by_year_and_specialty
          specialties_map = Specialty.where(id: visit_counts.values.flat_map(&:keys).uniq).index_by(&:id)
        %>
        <% if visit_counts.any? %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Visit Count by Calendar Year & Service Type</h2>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Year</th>
                    <% visit_counts.values.flat_map(&:keys).uniq.sort.each do |specialty_id| %>
                      <% specialty = specialties_map[specialty_id] %>
                      <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        <%= specialty&.name || "Specialty #{specialty_id}" %>
                      </th>
                    <% end %>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                  <% visit_counts.keys.sort.reverse.each do |year| %>
                    <tr class="hover:bg-gray-50">
                      <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900">
                        <%= year %>
                      </td>
                      <% visit_counts.values.flat_map(&:keys).uniq.sort.each do |specialty_id| %>
                        <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900 text-center">
                          <%= visit_counts[year]&.dig(specialty_id) || 0 %>
                        </td>
                      <% end %>
                      <td class="px-4 py-3 whitespace-nowrap text-sm font-semibold text-gray-900 text-center">
                        <%= @patient.total_visits_for_year(year) %>
                      </td>
                    </tr>
                  <% end %>
                  <!-- Total Row -->
                  <tr class="bg-gray-50 font-semibold">
                    <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900">
                      Total (All Years)
                    </td>
                    <% visit_counts.values.flat_map(&:keys).uniq.sort.each do |specialty_id| %>
                      <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900 text-center">
                        <%= @patient.total_visits_for_specialty(specialty_id) %>
                      </td>
                    <% end %>
                    <td class="px-4 py-3 whitespace-nowrap text-sm font-semibold text-gray-900 text-center">
                      <%= @patient.encounters.kept.where(status: [:ready_for_review, :reviewed, :ready_to_submit, :completed_confirmed, :sent]).count %>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p class="mt-4 text-xs text-gray-500">
              * Visit counts include encounters with status: Ready for Review, Reviewed, Ready to Submit, Completed/Confirmed, or Sent
            </p>
          </div>
        <% end %>

        <!-- Insurance Coverages -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-gray-900">Insurance Coverages</h2>
            <%= link_to "Manage Coverages",
                        admin_patient_insurance_coverages_path(patient_id: @patient.id),
                        class: "text-sm text-blue-600 hover:text-blue-800" %>
          </div>

          <% if @insurance_coverages.present? %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Order</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Payer</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plan</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Member ID</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Group Number</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Subscriber / Relation</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Effective / Term</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                  <% @insurance_coverages.each do |coverage| %>
                    <tr class="hover:bg-gray-50">
                      <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                     <%= coverage.coverage_order == 'primary' ? 'bg-blue-100 text-blue-800' : coverage.coverage_order == 'secondary' ? 'bg-green-100 text-green-800' : 'bg-purple-100 text-purple-800' %>">
                          <%= coverage.coverage_order.humanize %>
                        </span>
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">
                        <%= coverage.insurance_plan&.payer&.name || "—" %>
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">
                        <%= coverage.insurance_plan&.name || "Unknown Plan" %>
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-sm font-mono text-gray-900">
                        <%= coverage.member_id %>
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-sm font-mono text-gray-900">
                        <%= coverage.group_number.presence || "—" %>
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">
                        <div><%= coverage.subscriber_name %></div>
                        <div class="text-xs text-gray-500"><%= coverage.relationship_to_subscriber.humanize %></div>
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">
                        <%= coverage.effective_date&.strftime("%m/%d/%Y") || "—" %>
                        <% if coverage.termination_date.present? %>
                          – <%= coverage.termination_date.strftime("%m/%d/%Y") %>
                        <% end %>
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-sm">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= coverage.status_badge_class %>">
                          <%= coverage.status.humanize %>
                        </span>
                      </td>
                      <td class="px-4 py-3 whitespace-nowrap text-sm">
                        <div class="flex items-center space-x-2">
                          <%= link_to "View",
                                      admin_patient_insurance_coverage_path(coverage),
                                      target: "_blank",
                                      rel: "noopener",
                                      class: "text-blue-600 hover:text-blue-800" %>
                          <%= link_to "Edit",
                                      edit_admin_patient_insurance_coverage_path(coverage),
                                      class: "text-indigo-600 hover:text-indigo-800" %>
                          <button type="button"
                                  class="text-xs text-gray-600 hover:text-gray-900 underline"
                                  data-copy-member="<%= coverage.member_id %>"
                                  onclick="navigator.clipboard && navigator.clipboard.writeText(this.dataset.copyMember).then(() => { this.textContent = 'Copied'; setTimeout(() => { this.textContent = 'Copy'; }, 1500); }).catch(() => {});">
                            Copy
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-sm text-gray-500">No insurance coverage on file.</p>
          <% end %>
        </div>

        <!-- Notes -->
        <% if @patient.notes_nonphi.present? %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Notes</h2>
            <p class="text-sm text-gray-900 whitespace-pre-wrap"><%= @patient.notes_nonphi %></p>
          </div>
        <% end %>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Information -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Information</h3>
          <div class="space-y-3">
            <div>
              <label class="block text-sm font-medium text-gray-700">Created</label>
              <p class="text-sm text-gray-900"><%= @patient.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700">Last Updated</label>
              <p class="text-sm text-gray-900"><%= @patient.updated_at.strftime("%B %d, %Y at %I:%M %p") %></p>
            </div>
            
            <% if @patient.is_deceased? && @patient.deceased_at.present? %>
              <div>
                <label class="block text-sm font-medium text-gray-700">Deceased</label>
                <p class="text-sm text-gray-900"><%= @patient.deceased_at.strftime("%B %d, %Y") %></p>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Activity Summary -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Activity Summary</h3>
          <div class="space-y-3">
            <div class="flex justify-between">
              <span class="text-sm text-gray-600">Appointments</span>
              <span class="text-sm font-semibold text-gray-900"><%= @patient.appointments.count %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-gray-600">Encounters</span>
              <%= link_to admin_encounters_path(patient_id: @patient.id),
                          class: "text-sm font-semibold text-blue-600 hover:text-blue-800" do %>
                <%= @patient.encounters.count %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

