<div class="min-h-screen bg-gray-50 py-8">
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
    <% editable_payment = @encounter.payment_applications.map(&:payment).compact.uniq.select(&:service_line_editable?).max_by(&:updated_at) %>
    <!-- Header -->
    <div class="mb-8">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Encounter Details</h1>
          <p class="mt-2 text-gray-600">View encounter information</p>
        </div>
        <div class="flex space-x-3">
          <%= link_to "Back to Encounters", admin_encounters_path, class: "bg-gray-600 hover:bg-gray-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
          <%= link_to "Edit", edit_admin_encounter_path(@encounter), class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Encounter Information -->
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Encounter Information</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700">Organization</label>
              <p class="mt-1 text-sm text-gray-900"><%= @encounter.organization.name %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Patient</label>
              <p class="mt-1 text-sm text-gray-900"><%= @encounter.patient.first_name %> <%= @encounter.patient.last_name %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Provider</label>
              <p class="mt-1 text-sm text-gray-900"><%= @encounter.provider.full_name %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Date of Service</label>
              <p class="mt-1 text-sm text-gray-900"><%= @encounter.date_of_service.strftime("%B %d, %Y") %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Specialty</label>
              <p class="mt-1 text-sm text-gray-900"><%= @encounter.specialty.name %></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Payer</label>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @encounter.payer.present? ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                <%= @encounter.payer&.name || "—" %>
              </span>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Tenant Status</label>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @encounter.tenant_visible_status_badge_color %>">
                <%= @encounter.tenant_visible_status_label %>
              </span>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Shared Status</label>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @encounter.shared_status_badge_color %>">
                <%= @encounter.shared_status&.humanize || "—" %>
              </span>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Payment Status</label>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @encounter.payment_status_badge_color %>">
                <%= @encounter.payment_status_display_label %>
              </span>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700">Cascaded</label>
              <p class="mt-1 text-sm text-gray-900"><%= @encounter.cascaded? ? "Yes" : "No" %></p>
            </div>
          </div>
        </div>

        <!-- Diagnosis Codes -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Diagnosis Codes</h2>
          <% if @encounter.diagnosis_codes.any? %>
            <div class="space-y-2">
              <% @encounter.diagnosis_codes.each do |diagnosis| %>
                <div class="flex items-center space-x-2">
                  <span class="text-sm font-mono text-blue-600"><%= diagnosis.code %></span>
                  <span class="text-sm text-gray-700">-</span>
                  <span class="text-sm text-gray-700"><%= diagnosis.description %></span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500">No diagnosis codes assigned</p>
          <% end %>
        </div>

        <!-- CPT Codes / Procedures -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">CPT Codes</h2>
          <% procedure_rows = @encounter.procedure_line_items_for_summary %>
          <% if procedure_rows.any? %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Code</th>
                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
                    <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Units</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-100">
                  <% procedure_rows.each do |row| %>
                    <tr>
                      <td class="px-4 py-2 text-sm font-mono text-blue-700"><%= row[:code] %></td>
                      <td class="px-4 py-2 text-sm text-gray-800"><%= row[:description].presence || "—" %></td>
                      <td class="px-4 py-2 text-sm text-gray-800 text-right"><%= row[:units] || "—" %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-sm text-gray-500">No CPT codes/procedures available for this encounter.</p>
          <% end %>
        </div>

        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-gray-900">Payment Posting Summary</h2>
            <% if editable_payment.present? && current_user.permissions_for("admin", "payments", "update") %>
              <%= link_to "Edit Posted Payment", edit_admin_payment_path(editable_payment), class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
            <% end %>
          </div>

          <% if @encounter.payment_applications.any? %>
            <% summary_payment = editable_payment %>
            <% if summary_payment.present? %>
              <div class="mb-5 grid grid-cols-1 gap-3 md:grid-cols-4">
                <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
                  <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Original Payment</p>
                  <p class="mt-1 text-lg font-semibold text-gray-900">$<%= number_with_precision(summary_payment.original_payment_total, precision: 2, delimiter: ",") %></p>
                </div>
                <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
                  <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Interest</p>
                  <p class="mt-1 text-lg font-semibold text-gray-900">$<%= number_with_precision(summary_payment.interest_total, precision: 2, delimiter: ",") %></p>
                </div>
                <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
                  <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Adjustments</p>
                  <% adjustment_total = summary_payment.adjustments_total %>
                  <p class="mt-1 text-lg font-semibold <%= adjustment_total.negative? ? 'text-red-700' : 'text-gray-900' %>">
                    <%= adjustment_total.positive? ? "+" : "" %>$<%= number_with_precision(adjustment_total, precision: 2, delimiter: ",") %>
                  </p>
                </div>
                <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
                  <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Final Net Payment</p>
                  <p class="mt-1 text-lg font-semibold text-gray-900">$<%= number_with_precision(summary_payment.final_net_payment_total, precision: 2, delimiter: ",") %></p>
                </div>
              </div>
            <% end %>

            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Line</th>
                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Remit Reference</th>
                    <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Applied</th>
                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Paid Date</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-100">
                  <% @encounter.payment_applications.sort_by(&:created_at).each do |application| %>
                    <% claim_line = application.claim_line %>
                    <% code = claim_line&.procedure_code&.code || "00000" %>
                    <% description = claim_line&.procedure_code&.description || application.note.presence || "Interest Payment" %>
                    <tr>
                      <td class="px-4 py-2 text-sm text-gray-900">
                        <div class="font-medium"><%= code %></div>
                        <div class="text-xs text-gray-500"><%= description %></div>
                      </td>
                      <td class="px-4 py-2 text-sm text-gray-900"><%= application.payment&.remit_reference.presence || "—" %></td>
                      <td class="px-4 py-2 text-sm text-gray-900 text-right">$<%= number_with_precision(application.amount_applied || 0, precision: 2, delimiter: ",") %></td>
                      <td class="px-4 py-2 text-sm text-gray-900"><%= application.line_status_display_label %></td>
                      <td class="px-4 py-2 text-sm text-gray-900"><%= (application.payment&.payment_date || application.payment&.created_at)&.strftime("%m/%d/%Y") || "—" %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

            <% if summary_payment&.payment_adjustments&.any? %>
              <div class="mt-5">
                <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-3">Adjustments</h3>
                <div class="space-y-2">
                  <% summary_payment.payment_adjustments.order(:adjustment_date, :created_at).each do |adjustment| %>
                    <div class="flex flex-col gap-2 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 md:flex-row md:items-center md:justify-between">
                      <div>
                        <p class="text-sm font-medium text-gray-900">
                          <%= adjustment.signed_amount.positive? ? "+" : "" %>$<%= number_with_precision(adjustment.signed_amount, precision: 2, delimiter: ",") %>
                          <span class="ml-2 text-gray-600"><%= adjustment.reason.presence || adjustment.adjustment_type.humanize %></span>
                        </p>
                        <% if adjustment.notes.present? %>
                          <p class="mt-1 text-xs text-gray-500"><%= adjustment.notes %></p>
                        <% end %>
                      </div>
                      <div class="text-xs text-gray-500">
                        <%= adjustment.adjustment_date&.strftime("%m/%d/%Y") || "—" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% else %>
            <p class="text-sm text-gray-500">No payment posting has been recorded for this encounter yet.</p>
          <% end %>
        </div>

        <!-- Notes -->
        <% if @encounter.notes.present? %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Clinical Notes</h2>
            <p class="text-sm text-gray-900 whitespace-pre-wrap"><%= @encounter.notes %></p>
          </div>
        <% end %>

        <!-- Files & Attachments -->
        <%= render "shared/encounter_summary_files", namespace: "admin" %>

        <!-- Provider Notes Section -->
        <%= render "shared/provider_notes", namespace: "admin" %>

        <!-- Comments Section -->
        <%= render "shared/encounter_comments", namespace: "admin" %>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Actions -->
        <% if current_user.permissions_for("admin", "encounters", "submit_for_billing") %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Actions</h3>
            <div class="space-y-2">
              <button type="button" 
                      onclick="openEzclaimModal('encounterBillingModal', '<%= billing_data_admin_encounter_path(@encounter) %>', 'claim')"
                      class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-lg transition-colors">
                Submit for Billing
              </button>
              <% can_edit_posted_payment = editable_payment.present? && current_user.permissions_for("admin", "payments", "update") %>
              <%= link_to(can_edit_posted_payment ? "Edit Posted Payment" : "Post Payments",
                          can_edit_posted_payment ? edit_admin_payment_path(editable_payment) : new_admin_payment_path(encounter_id: @encounter.id),
                          class: "w-full inline-flex justify-center bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
            </div>
          </div>
        <% end %>

        <!-- Status Information -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Information</h3>
          <div class="space-y-3">
            <div>
              <label class="block text-sm font-medium text-gray-700">Created</label>
              <p class="text-sm text-gray-900"><%= @encounter.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700">Last Updated</label>
              <p class="text-sm text-gray-900"><%= @encounter.updated_at.strftime("%B %d, %Y at %I:%M %p") %></p>
            </div>
            
            <% if @encounter.cascaded? %>
              <div>
                <label class="block text-sm font-medium text-gray-700">Display Status</label>
                <p class="text-sm text-gray-900"><%= @encounter.display_status_text %></p>
              </div>
            <% end %>

            <% if @encounter.clinical_documentations.with_file.any? %>
              <div>
                <label class="block text-sm font-medium text-gray-700">Clinical Documentation</label>
                <ul class="mt-1 space-y-1 text-sm text-gray-900">
                  <% @encounter.clinical_documentations.with_file.each do |doc| %>
                    <li class="flex items-center justify-between gap-2">
                      <span class="truncate"><%= doc.file.filename %></span>
                      <%= link_to "View", rails_blob_path(doc.file), target: "_blank", rel: "noopener", class: "text-xs text-blue-600 hover:text-blue-800 whitespace-nowrap" %>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%= render 'shared/ezclaim_modal',
    modal_id: 'encounterBillingModal',
    claim_id: @encounter.id,
    data_url: billing_data_admin_encounter_path(@encounter),
    submit_url: submit_for_billing_admin_encounter_path(@encounter),
    search_url: procedure_codes_search_admin_encounter_path(@encounter),
    diagnosis_search_url: diagnosis_codes_search_admin_encounter_path(@encounter),
    title: 'Submit for Billing',
    modal_type: 'claim'
%>
