<div class="min-h-screen bg-gray-50 py-8">
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <div class="flex justify-between items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900">Edit Posted Payment</h2>
          <p class="mt-2 text-gray-600">Update service-line statuses and payment amounts for this posted payment.</p>
        </div>
        <div>
          <% if @encounter %>
            <%= link_to "Back to Encounter",
                        admin_encounter_path(@encounter),
                        class: "bg-gray-600 hover:bg-gray-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
          <% else %>
            <%= link_to "Back to Payments",
                        admin_payments_path,
                        class: "bg-gray-600 hover:bg-gray-700 text-white font-medium py-2 px-4 rounded-lg transition-colors" %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <%= render "form",
                 payment: @payment,
                 encounter: @encounter,
                 claim_lines: @claim_lines,
                 applications_by_line: @applications_by_line,
                 billed_amounts_by_line_id: @billed_amounts_by_line_id %>
    </div>
  </div>
</div>
