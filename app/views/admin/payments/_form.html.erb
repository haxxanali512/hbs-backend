<%= form_with model: [:admin, payment],
              url: payment.persisted? ? admin_payment_path(payment) : admin_payments_path,
              method: payment.persisted? ? :patch : :post,
              id: "manual-payment-form",
              class: "space-y-6" do |f| %>
  <% if payment.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(payment.errors.count, "error") %> prohibited this payment from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% payment.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% if flash[:alert].present? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-3 text-sm text-red-700">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <% if encounter %>
    <%= hidden_field_tag :encounter_id, encounter.id %>
  <% end %>

  <% if encounter %>
    <!-- Encounter Summary -->
    <div class="space-y-4">
      <h3 class="text-lg font-medium text-gray-900">Encounter Summary</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <div class="text-sm font-medium text-gray-700 mb-1">Patient</div>
          <div class="text-sm text-gray-900">
            <%= encounter.patient.first_name %> <%= encounter.patient.last_name %>
          </div>
        </div>
        <div>
          <div class="text-sm font-medium text-gray-700 mb-1">Provider</div>
          <div class="text-sm text-gray-900">
            <%= encounter.provider.full_name %>
          </div>
        </div>
        <div>
          <div class="text-sm font-medium text-gray-700 mb-1">Date of Service</div>
          <div class="text-sm text-gray-900">
            <%= encounter.date_of_service&.strftime("%m/%d/%Y") %>
          </div>
        </div>
        <div>
          <div class="text-sm font-medium text-gray-700 mb-1">Current Payment Status</div>
          <div class="text-sm text-gray-900">
            <%= encounter.payment_status&.to_s&.humanize || "Unpaid" %>
          </div>
        </div>
        <div>
          <div class="text-sm font-medium text-gray-700 mb-1">Total Paid</div>
          <div class="text-sm text-gray-900">
            $<%= number_with_precision(encounter.total_paid_amount || 0, precision: 2, delimiter: ",") %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Payment Header -->
  <div class="space-y-4">
    <h3 class="text-lg font-medium text-gray-900">Payment Header</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <% default_payer = @default_payer %>
        <% selected_payer = payment.payer || default_payer %>
        <%= f.label :payer_id, "Payer", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :payer_id,
                     options_from_collection_for_select(@payers || Payer.active_only.order(:name), :id, :name, selected_payer&.id),
                     { prompt: "Select payer..." },
                     class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 sm:text-sm" %>
      </div>
      <div>
        <%= f.label :payment_date, "Payment Date", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :payment_date,
                         value: (payment.payment_date || Date.current),
                         class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 sm:text-sm" %>
      </div>
      <div class="md:col-span-1">
        <%= f.label :remit_reference, "Remit Reference", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :remit_reference,
                         value: payment.remit_reference,
                         placeholder: "Optional reference (e.g. check #, ERA ID)",
                         class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 sm:text-sm" %>
      </div>
    </div>

    <div>
      <%= f.label :notes, "Payment Notes", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :notes,
                      value: payment.notes,
                      rows: 3,
                      placeholder: "Optional internal notes for this payment",
                      class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :generate_invoice, {}, "1", "0" %>
      <%= f.label :generate_invoice,
                  "Generate patient invoice for this payment (optional)",
                  class: "text-sm text-gray-700" %>
    </div>
  </div>

  <% if encounter %>
    <!-- Service Lines -->
    <div class="space-y-4">
      <h3 class="text-lg font-medium text-gray-900">Service Lines</h3>

      <% if claim_lines.present? %>
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
          <div class="px-4 py-3 flex items-center justify-between bg-white border-b border-gray-200">
            <div>
              <% interest_application = applications_by_line[nil] %>
              <% interest_line_visible = (interest_application&.amount_applied || 0).to_d.positive? || interest_application&.line_status.present? %>
              <button
                type="button"
                id="add-interest-line"
                class="inline-flex items-center gap-2 text-sm font-medium text-indigo-700 hover:text-indigo-800"
                onclick="showInterestLine()"
                <%= "disabled" if interest_line_visible %>
                aria-label="Add Interest Payment"
              >
                <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-indigo-50 text-indigo-700 border border-indigo-100">
                  +
                </span>
                Add Interest
              </button>
            </div>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Code</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
                  <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Billed</th>
                  <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Paid Amount</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Denial Reason</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200" id="service-lines-body">
              <% interest_application = applications_by_line[nil] %>
              <% current_status = interest_application&.line_status&.to_s %>
              <tr id="service-line-interest" class="hover:bg-gray-50 <%= (interest_application&.amount_applied || 0).to_d.positive? || interest_application&.line_status.present? ? '' : 'hidden' %>" data-billed-amount="0">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  00000
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  Interest Payment
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 align-middle">
                  <%= number_with_precision(0, precision: 2, delimiter: ",") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 align-middle">
                  <div class="flex justify-end">
                    <input
                      type="number"
                      name="service_lines[interest][amount_paid]"
                      step="0.01"
                      min="0"
                      value="<%= interest_application&.amount_applied %>"
                      class="inline-block w-24 border border-gray-300 rounded-md px-2 py-1 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm text-right amount-input"
                      data-service-line-id="interest"
                    />
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 align-middle">
                  <div class="flex">
                    <select
                      name="service_lines[interest][status]"
                      class="mt-1 inline-block w-44 border border-gray-300 rounded-md px-2 py-1 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm status-select"
                      data-service-line-id="interest"
                    >
                      <% PaymentApplication::LINE_STATUS_OPTIONS.each do |label, value| %>
                        <option value="<%= value %>" <%= current_status == value || (value.blank? && current_status.blank?) ? "selected" : "" %>><%= label %></option>
                      <% end %>
                    </select>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 align-middle">
                  <textarea
                    name="service_lines[interest][denial_reason]"
                    rows="2"
                    class="mt-1 block w-64 max-w-xs border border-gray-300 rounded-md px-2 py-1 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm denial-textarea"
                    data-service-line-id="interest"
                    <%= current_status == "denied" ? "" : "style=\"display:none;\"" %>
                  ><%= interest_application&.denial_reason %></textarea>
                </td>
              </tr>
              <% claim_lines.each do |line| %>
                <% application = applications_by_line[line.id] %>
                <% billed_amounts = local_assigns[:billed_amounts_by_line_id] || {} %>
                <% billed = billed_amounts[line.id] || (line.respond_to?(:amount_billed) ? line.amount_billed : nil) %>
                <tr id="service-line-<%= line.id %>" class="hover:bg-gray-50" data-billed-amount="<%= (billed || 0).to_d %>">
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= line.procedure_code&.code || "—" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= line.procedure_code&.description || "—" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 align-middle">
                    $<%= number_with_precision(billed || 0, precision: 2, delimiter: ",") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 align-middle">
                    <div class="flex justify-end">
                      <input
                        type="number"
                        name="service_lines[<%= line.id %>][amount_paid]"
                        step="0.01"
                        min="0"
                        value="<%= application&.amount_applied %>"
                        class="inline-block w-24 border border-gray-300 rounded-md px-2 py-1 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm text-right amount-input"
                        data-service-line-id="<%= line.id %>"
                      />
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 align-middle">
                    <div class="flex">
                      <select
                        name="service_lines[<%= line.id %>][status]"
                        class="mt-1 inline-block w-44 border border-gray-300 rounded-md px-2 py-1 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm status-select"
                        data-service-line-id="<%= line.id %>"
                      >
                        <% current_status = application&.line_status&.to_s %>
                        <% PaymentApplication::LINE_STATUS_OPTIONS.each do |label, value| %>
                          <option value="<%= value %>" <%= current_status == value || (value.blank? && current_status.blank?) ? "selected" : "" %>><%= label %></option>
                        <% end %>
                      </select>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 align-middle">
                    <textarea
                      name="service_lines[<%= line.id %>][denial_reason]"
                      rows="2"
                      class="mt-1 block w-64 max-w-xs border border-gray-300 rounded-md px-2 py-1 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm denial-textarea"
                      data-service-line-id="<%= line.id %>"
                      <%= current_status == "denied" ? "" : "style=\"display:none;\"" %>
                    ><%= application&.denial_reason %></textarea>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        </div>

        <div class="mt-3 text-sm text-gray-700 space-y-1">
          <div>
            <span class="font-medium">Encounter Total Billed (from entries):</span>
            <span id="encounter-total-billed" class="font-semibold text-gray-900">$0.00</span>
          </div>
          <div>
            <span class="font-medium">Encounter Total Paid (from entries):</span>
            <span id="encounter-total-paid" class="font-semibold text-gray-900">$0.00</span>
          </div>
          <div>
            <span class="font-medium">Patient Responsibility (Billed - Paid):</span>
            <span id="patient-responsibility" class="font-semibold text-gray-900">$0.00</span>
          </div>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">
          No claim/service lines found for this encounter. Payments can be posted once a claim with service lines exists.
        </p>
      <% end %>
    </div>

    <div class="space-y-4">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-medium text-gray-900">Adjustments</h3>
        <button type="button"
                id="add-adjustment-row"
                class="inline-flex items-center gap-2 rounded-md border border-indigo-200 bg-indigo-50 px-3 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100">
          <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-indigo-200 bg-white text-indigo-700">+</span>
          Add Adjustment
        </button>
      </div>

      <div class="rounded-lg border border-gray-200 bg-white shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Type</th>
                <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-500">Amount</th>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Date</th>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Reason</th>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Notes</th>
                <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-500">Actions</th>
              </tr>
            </thead>
            <tbody id="payment-adjustments-body" class="divide-y divide-gray-200 bg-white">
              <% @payment_adjustments.each_with_index do |adjustment, index| %>
                <% row_key = adjustment.id || "existing_#{index}" %>
                <tr class="adjustment-row" data-adjustment-row="true">
                  <td class="px-4 py-3">
                    <input type="hidden" name="payment_adjustments[<%= row_key %>][id]" value="<%= adjustment.id %>">
                    <select name="payment_adjustments[<%= row_key %>][adjustment_type]"
                            class="adjustment-type w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                      <option value="increase" <%= adjustment.increase? ? "selected" : "" %>>Increase</option>
                      <option value="decrease" <%= adjustment.decrease? ? "selected" : "" %>>Decrease</option>
                    </select>
                  </td>
                  <td class="px-4 py-3">
                    <input type="number"
                           name="payment_adjustments[<%= row_key %>][amount]"
                           step="0.01"
                           min="0.01"
                           value="<%= adjustment.amount %>"
                           class="adjustment-amount w-full rounded-md border border-gray-300 px-3 py-2 text-right text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                  </td>
                  <td class="px-4 py-3">
                    <input type="date"
                           name="payment_adjustments[<%= row_key %>][adjustment_date]"
                           value="<%= adjustment.adjustment_date || payment.payment_date || Date.current %>"
                           class="adjustment-date w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                  </td>
                  <td class="px-4 py-3">
                    <input type="text"
                           name="payment_adjustments[<%= row_key %>][reason]"
                           value="<%= adjustment.reason %>"
                           placeholder="Supplemental reprocessing, recoupment..."
                           class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                  </td>
                  <td class="px-4 py-3">
                    <input type="text"
                           name="payment_adjustments[<%= row_key %>][notes]"
                           value="<%= adjustment.notes %>"
                           placeholder="Optional notes"
                           class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                  </td>
                  <td class="px-4 py-3 text-right">
                    <button type="button"
                            class="remove-adjustment-row text-sm font-medium text-red-600 hover:text-red-800">
                      Remove
                    </button>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <div id="payment-adjustments-empty-state" class="<%= @payment_adjustments.any? ? 'hidden' : '' %> px-4 py-6 text-sm text-gray-500">
          No adjustments added yet. Use adjustments for supplemental increases, recoupments, or other post-payment corrections.
        </div>
      </div>

      <template id="payment-adjustment-row-template">
        <tr class="adjustment-row" data-adjustment-row="true">
          <td class="px-4 py-3">
            <select data-name="adjustment_type"
                    class="adjustment-type w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
              <option value="increase">Increase</option>
              <option value="decrease">Decrease</option>
            </select>
          </td>
          <td class="px-4 py-3">
            <input type="number"
                   data-name="amount"
                   step="0.01"
                   min="0.01"
                   class="adjustment-amount w-full rounded-md border border-gray-300 px-3 py-2 text-right text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </td>
          <td class="px-4 py-3">
            <input type="date"
                   data-name="adjustment_date"
                   value="<%= payment.payment_date || Date.current %>"
                   class="adjustment-date w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </td>
          <td class="px-4 py-3">
            <input type="text"
                   data-name="reason"
                   placeholder="Supplemental reprocessing, recoupment..."
                   class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </td>
          <td class="px-4 py-3">
            <input type="text"
                   data-name="notes"
                   placeholder="Optional notes"
                   class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </td>
          <td class="px-4 py-3 text-right">
            <button type="button"
                    class="remove-adjustment-row text-sm font-medium text-red-600 hover:text-red-800">
              Remove
            </button>
          </td>
        </tr>
      </template>

      <div class="grid grid-cols-1 gap-3 md:grid-cols-4">
        <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Original Payment</p>
          <p id="payment-original-total" class="mt-1 text-lg font-semibold text-gray-900">$0.00</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Interest</p>
          <p id="payment-interest-total" class="mt-1 text-lg font-semibold text-gray-900">$0.00</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Adjustments</p>
          <p id="payment-adjustments-total" class="mt-1 text-lg font-semibold text-gray-900">$0.00</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Final Net Payment</p>
          <p id="payment-final-net-total" class="mt-1 text-lg font-semibold text-gray-900">$0.00</p>
        </div>
      </div>
    </div>
  <% else %>
    <!-- Info for non-encounter payments -->
    <div class="bg-blue-50 border border-blue-200 rounded-md p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M18 10A8 8 0 11 2 10a8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3 text-sm text-blue-800">
          This payment is not tied to a specific encounter. After saving, you can allocate it using other workflows.
        </div>
      </div>
    </div>
  <% end %>

  <div id="client-validation-errors" class="hidden bg-red-50 border border-red-200 rounded-md p-3 text-sm text-red-700"></div>

  <!-- Form Actions -->
  <div class="flex justify-end space-x-3 pt-6 border-t border-gray-200">
    <% in_modal = local_assigns[:modal] %>
    <% if in_modal && encounter %>
      <button type="button"
              onclick="closeManualPaymentModal()"
              class="bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium py-2 px-4 rounded-md transition-colors">
        Cancel
      </button>
    <% else %>
      <%= link_to "Cancel",
                  encounter ? admin_encounter_path(encounter) : admin_payments_path,
                  class: "bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium py-2 px-4 rounded-md transition-colors" %>
    <% end %>
    <%= f.submit(payment.persisted? ? "Save Payment Changes" : (encounter ? "Post Payments" : "Create Payment"),
                 id: "post-payments-submit",
                 class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md transition-colors cursor-pointer") %>
  </div>
<% end %>

<% if encounter %>
  <script>
    (function() {
      function getForm() {
        return document.getElementById('manual-payment-form');
      }

      function adjustmentRows(form) {
        return form.querySelectorAll('#payment-adjustments-body tr.adjustment-row');
      }

      function updateAdjustmentEmptyState(form) {
        var emptyState = form.querySelector('#payment-adjustments-empty-state');
        if (!emptyState) { return; }
        emptyState.classList.toggle('hidden', adjustmentRows(form).length > 0);
      }

      function buildAdjustmentInputName(rowKey, fieldName) {
        return 'payment_adjustments[' + rowKey + '][' + fieldName + ']';
      }

      function addAdjustmentRow() {
        var form = getForm();
        if (!form) { return; }

        var template = form.querySelector('#payment-adjustment-row-template');
        var tbody = form.querySelector('#payment-adjustments-body');
        if (!template || !tbody) { return; }

        var clone = template.content.cloneNode(true);
        var row = clone.querySelector('tr');
        var rowKey = 'new_' + Date.now() + '_' + Math.floor(Math.random() * 1000);

        clone.querySelectorAll('[data-name]').forEach(function(element) {
          element.name = buildAdjustmentInputName(rowKey, element.getAttribute('data-name'));
        });

        tbody.appendChild(clone);
        bindAdjustmentRowEvents(form, row);
        updateAdjustmentEmptyState(form);
        updateTotal();
        validateFormReadiness(true);
      }

      function removeAdjustmentRow(button) {
        var form = getForm();
        if (!form) { return; }
        var row = button.closest('tr.adjustment-row');
        if (!row) { return; }
        row.remove();
        updateAdjustmentEmptyState(form);
        updateTotal();
        validateFormReadiness(true);
      }

      function signedAdjustmentAmount(row) {
        if (!row) { return 0.0; }

        var amountInput = row.querySelector('.adjustment-amount');
        var typeSelect = row.querySelector('.adjustment-type');
        if (!amountInput || !typeSelect) { return 0.0; }

        var amount = parseFloat(amountInput.value || '0');
        if (isNaN(amount)) { amount = 0.0; }

        return typeSelect.value === 'decrease' ? -amount : amount;
      }

      // Used by the "Add Interest" button in the service lines table.
      // Reveals the Interest row (service_lines[interest][...]) and updates totals.
      window.showInterestLine = function() {
        var row = document.getElementById('service-line-interest');
        if (!row) { return; }
        row.classList.remove('hidden');

        var btn = document.getElementById('add-interest-line');
        if (btn) { btn.disabled = true; }

        var statusSelect = document.querySelector('select.status-select[data-service-line-id="interest"]');
        var denialTextarea = document.querySelector('textarea.denial-textarea[data-service-line-id="interest"]');
        if (statusSelect && denialTextarea) {
          if (statusSelect.value === 'denied') {
            denialTextarea.style.display = '';
          } else {
            denialTextarea.style.display = 'none';
            denialTextarea.value = '';
          }
        }

        updateTotal();
        validateFormReadiness(true);
      };

      function updateTotal() {
        var form = getForm();
        if (!form) { return; }

        var rows = form.querySelectorAll('#service-lines-body tr');
        var originalTotal = 0.0;
        var interestTotal = 0.0;
        var totalBilled = 0.0;

        rows.forEach(function(row) {
          var lineId = row.id.replace('service-line-', '');
          var amountInput = form.querySelector('input.amount-input[data-service-line-id="' + lineId + '"]');
          var statusSelect = form.querySelector('select.status-select[data-service-line-id="' + lineId + '"]');

          if (!amountInput || !statusSelect) { return; }

          var amount = parseFloat(amountInput.value || "0");
          var status = statusSelect.value;

          var billed = parseFloat(row.getAttribute('data-billed-amount') || "0");
          if (!isNaN(billed) && billed > 0) {
            totalBilled += billed;
          }

          if (!isNaN(amount) && amount > 0 && (status === 'paid' || status === 'adjusted' || status === 'partial' || status === 'partial_deductible')) {
            if (lineId === 'interest') {
              interestTotal += amount;
            } else {
              originalTotal += amount;
            }
          }
        });

        var adjustmentsTotal = 0.0;
        adjustmentRows(form).forEach(function(row) {
          adjustmentsTotal += signedAdjustmentAmount(row);
        });

        var finalNetTotal = originalTotal + interestTotal + adjustmentsTotal;
        if (finalNetTotal < 0) { finalNetTotal = 0; }

        var paidEl = form.querySelector('#encounter-total-paid');
        if (paidEl) { paidEl.textContent = '$' + finalNetTotal.toFixed(2); }

        var billedEl = form.querySelector('#encounter-total-billed');
        if (billedEl) { billedEl.textContent = '$' + totalBilled.toFixed(2); }

        var patientEl = form.querySelector('#patient-responsibility');
        if (patientEl) {
          var responsibility = totalBilled - finalNetTotal;
          if (responsibility < 0) { responsibility = 0; }
          patientEl.textContent = '$' + responsibility.toFixed(2);
        }

        var originalEl = form.querySelector('#payment-original-total');
        if (originalEl) { originalEl.textContent = '$' + originalTotal.toFixed(2); }

        var interestEl = form.querySelector('#payment-interest-total');
        if (interestEl) { interestEl.textContent = '$' + interestTotal.toFixed(2); }

        var adjustmentsEl = form.querySelector('#payment-adjustments-total');
        if (adjustmentsEl) {
          var prefix = adjustmentsTotal > 0 ? '+' : '';
          adjustmentsEl.textContent = prefix + '$' + adjustmentsTotal.toFixed(2);
        }

        var finalNetEl = form.querySelector('#payment-final-net-total');
        if (finalNetEl) { finalNetEl.textContent = '$' + finalNetTotal.toFixed(2); }
      }

      function validateFormReadiness(showErrors) {
        var form = getForm();
        if (!form) { return; }
        if (typeof showErrors === 'undefined') { showErrors = false; }

        var errors = [];
        var rows = form.querySelectorAll('#service-lines-body tr');
        var hasAnyLineAction = false;

        var paymentDateInput = form.querySelector('input[name="payment[payment_date]"]');
        if (paymentDateInput && !paymentDateInput.value) {
          errors.push('Payment date is required.');
        }

        var payerInput = form.querySelector('input[name="payment[payer_id]"], select[name="payment[payer_id]"]');
        if (payerInput && !payerInput.value) {
          errors.push('Payer is required.');
        }

        rows.forEach(function(row) {
          var lineId = row.id.replace('service-line-', '');
          var amountInput = form.querySelector('input.amount-input[data-service-line-id="' + lineId + '"]');
          var statusSelect = form.querySelector('select.status-select[data-service-line-id="' + lineId + '"]');
          var denialInput = form.querySelector('textarea.denial-textarea[data-service-line-id="' + lineId + '"]');

          if (!amountInput || !statusSelect) { return; }

          var rawAmount = amountInput.value || "0";
          var amount = parseFloat(rawAmount);
          if (isNaN(amount)) { amount = 0; }
          var status = statusSelect.value;

          if (status || amount > 0) {
            hasAnyLineAction = true;
          }

          if (status === 'denied') {
            if (!denialInput || !denialInput.value || denialInput.value.trim() === '') {
              errors.push('Denial reason is required for denied service lines.');
            }
          }

          if (status === 'paid' || status === 'adjusted' || status === 'partial' || status === 'partial_deductible') {
            if (!(amount > 0)) {
              errors.push('Paid/Adjusted/Partial/Partial Deductible lines must have amount greater than 0.');
            }
          }
        });

        var adjustmentsTotal = 0.0;
        adjustmentRows(form).forEach(function(row) {
          var amountInput = row.querySelector('.adjustment-amount');
          var dateInput = row.querySelector('.adjustment-date');
          var amount = parseFloat(amountInput && amountInput.value ? amountInput.value : '0');
          if (isNaN(amount)) { amount = 0.0; }

          if (amount > 0) {
            if (!dateInput || !dateInput.value) {
              errors.push('Adjustment date is required for each adjustment.');
            }
            hasAnyLineAction = true;
          }

          adjustmentsTotal += signedAdjustmentAmount(row);
        });

        var currentPaidTotal = 0.0;
        rows.forEach(function(row) {
          var lineId = row.id.replace('service-line-', '');
          var amountInput = form.querySelector('input.amount-input[data-service-line-id="' + lineId + '"]');
          var statusSelect = form.querySelector('select.status-select[data-service-line-id="' + lineId + '"]');
          if (!amountInput || !statusSelect) { return; }
          var amount = parseFloat(amountInput.value || '0');
          if (isNaN(amount)) { amount = 0.0; }
          if (amount > 0 && (statusSelect.value === 'paid' || statusSelect.value === 'adjusted' || statusSelect.value === 'partial' || statusSelect.value === 'partial_deductible')) {
            currentPaidTotal += amount;
          }
        });

        if ((currentPaidTotal + adjustmentsTotal) < 0) {
          errors.push('Adjustments cannot reduce the final net payment below zero.');
        }

        if (!hasAnyLineAction) {
          errors.push('Add at least one service-line payment entry before posting.');
        }

        var uniqueErrors = Array.from(new Set(errors));
        var errorBox = form.querySelector('#client-validation-errors');
        var submitBtn = form.querySelector('#post-payments-submit');
        var isValid = uniqueErrors.length === 0;

        if (errorBox) {
          if (isValid || !showErrors) {
            errorBox.classList.add('hidden');
            errorBox.innerHTML = '';
          } else {
            errorBox.classList.remove('hidden');
            errorBox.innerHTML = '<ul class="list-disc pl-5 space-y-1">' + uniqueErrors.map(function(msg) {
              return '<li>' + msg + '</li>';
            }).join('') + '</ul>';
          }
        }

        if (submitBtn) {
          submitBtn.disabled = !isValid;
          if (isValid) {
            submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
          } else {
            submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
          }
        }
      }

      function bindAdjustmentRowEvents(form, row) {
        if (!row) { return; }

        row.querySelectorAll('.adjustment-type, .adjustment-amount, .adjustment-date').forEach(function(input) {
          input.addEventListener('input', function() {
            updateTotal();
            validateFormReadiness(true);
          });
          input.addEventListener('change', function() {
            updateTotal();
            validateFormReadiness(true);
          });
        });

        var removeButton = row.querySelector('.remove-adjustment-row');
        if (removeButton) {
          removeButton.addEventListener('click', function() {
            removeAdjustmentRow(removeButton);
          });
        }
      }

      function bindEvents() {
        var form = getForm();
        if (!form) { return; }
        if (form.dataset.validationBound === '1') {
          updateTotal();
          validateFormReadiness(false);
          return;
        }
        form.dataset.validationBound = '1';

        form.querySelectorAll('input.amount-input').forEach(function(input) {
          input.addEventListener('input', function() {
            updateTotal();
            validateFormReadiness(true);
          });
          input.addEventListener('change', function() {
            updateTotal();
            validateFormReadiness(true);
          });
        });

        var paymentDateInput = form.querySelector('input[name="payment[payment_date]"]');
        if (paymentDateInput) {
          paymentDateInput.addEventListener('change', function() { validateFormReadiness(true); });
        }

        var payerInput = form.querySelector('input[name="payment[payer_id]"], select[name="payment[payer_id]"]');
        if (payerInput) {
          payerInput.addEventListener('change', function() { validateFormReadiness(true); });
        }

        form.querySelectorAll('select.status-select').forEach(function(select) {
          select.addEventListener('change', function(event) {
            var lineId = event.target.getAttribute('data-service-line-id');
            var status = event.target.value;
            var textarea = form.querySelector('textarea.denial-textarea[data-service-line-id="' + lineId + '"]');

            if (textarea) {
              if (status === 'denied') {
                textarea.style.display = '';
              } else {
                textarea.style.display = 'none';
                textarea.value = '';
              }
            }

            updateTotal();
            validateFormReadiness(true);
          });
        });

        form.querySelectorAll('textarea.denial-textarea').forEach(function(textarea) {
          textarea.addEventListener('input', function() { validateFormReadiness(true); });
        });

        var addAdjustmentButton = form.querySelector('#add-adjustment-row');
        if (addAdjustmentButton) {
          addAdjustmentButton.addEventListener('click', addAdjustmentRow);
        }

        adjustmentRows(form).forEach(function(row) {
          bindAdjustmentRowEvents(form, row);
        });

        form.addEventListener('submit', function(event) {
          validateFormReadiness(true);
          var submitBtn = form.querySelector('#post-payments-submit');
          if (submitBtn && submitBtn.disabled) {
            event.preventDefault();
          }
        });

        updateTotal();
        updateAdjustmentEmptyState(form);
        validateFormReadiness(false);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bindEvents);
      } else {
        bindEvents();
      }

      document.addEventListener('turbo:load', bindEvents);
      document.addEventListener('turbo:frame-load', function(event) {
        if (!event.target) { return; }
        if (event.target.id === 'manual-payment-modal-frame' || event.target.querySelector('#manual-payment-form')) {
          bindEvents();
        }
      });
    })();
  </script>
<% end %>
