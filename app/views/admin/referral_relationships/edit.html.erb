<div class="w-full py-8 px-4 sm:px-6 lg:px-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Edit Referral Relationship</h1>
    <%= link_to "Back", admin_referral_relationship_path(@referral_relationship), class: "text-sm text-gray-700 hover:text-gray-900" %>
  </div>

  <%= form_with model: [ :admin, @referral_relationship ], class: "rounded-2xl border border-gray-200 bg-white p-8 shadow-sm space-y-6", data: { turbo: false } do |f| %>
    <h3 class="text-base font-semibold text-gray-900">Relationship Details</h3>
    <div class="grid gap-6 md:grid-cols-2">
      <div>
        <label class="block text-sm font-medium text-gray-700">Contract Signed Date</label>
        <%= f.date_field :contract_signed_date, class: "mt-2 block h-11 w-full rounded-lg border border-gray-200 px-4 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Tier</label>
        <%= f.text_field :tier_selected, class: "mt-2 block h-11 w-full rounded-lg border border-gray-200 px-4 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Commission Start</label>
        <%= f.date_field :commission_start_date, class: "mt-2 block h-11 w-full rounded-lg border border-gray-200 px-4 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Commission End</label>
        <%= f.date_field :commission_end_date, class: "mt-2 block h-11 w-full rounded-lg border border-gray-200 px-4 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Status</label>
        <%= f.select :status, ReferralRelationship.statuses.keys.map { |key| [key.humanize, key] }, {}, class: "mt-2 block h-11 w-full rounded-lg border border-gray-200 px-4 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Eligibility</label>
        <%= f.select :eligibility_status, ReferralRelationship.eligibility_statuses.keys.map { |key| [key.humanize, key] }, {}, class: "mt-2 block h-11 w-full rounded-lg border border-gray-200 px-4 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700">Ineligibility Reason</label>
      <%= f.text_area :ineligibility_reason, rows: 4, class: "mt-2 block w-full rounded-lg border border-gray-200 px-4 py-3 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div class="flex items-center justify-end gap-4">
      <%= link_to "Cancel", admin_referral_relationship_path(@referral_relationship), class: "text-sm text-gray-700 hover:text-gray-900" %>
      <%= f.submit "Save Changes", class: "inline-flex items-center rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" %>
    </div>
  <% end %>
</div>
