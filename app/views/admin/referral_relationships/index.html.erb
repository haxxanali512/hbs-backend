<div class="min-h-screen bg-gray-50 py-8">
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Referral Relationships</h1>
          <p class="mt-2 text-gray-600">Track referred practices, eligibility windows, and lifetime value</p>
        </div>
        <div>
          <%= link_to "Export CSV", export_admin_referral_relationships_path, class: "bg-white hover:bg-gray-50 text-gray-700 text-sm font-medium px-4 py-2 rounded-md border border-gray-300" %>
        </div>
      </div>
    </div>

    <%= render "shared/filters" %>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Partner</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Referred Practice</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Signed Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Start Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">End Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Revenue To Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Commission To Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% if @referral_relationships.present? && @referral_relationships.any? %>
              <% @referral_relationships.each do |relationship| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= relationship.referral_partner.full_name %></td>
                  <td class="px-6 py-4 whitespace-nowrap"><%= link_to relationship.referred_practice_name, admin_referral_relationship_path(relationship), class: "text-sm font-medium text-indigo-600 hover:text-indigo-700" %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= relationship.contract_signed_date&.strftime("%b %d, %Y") || "—" %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= relationship.commission_start_date&.strftime("%b %d, %Y") || "—" %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= relationship.commission_end_date&.strftime("%b %d, %Y") || "—" %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= number_to_currency(relationship.total_revenue_to_date) %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= number_to_currency(relationship.total_commission_to_date) %></td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% classes = case relationship.status
                      when "active" then "bg-emerald-50 text-emerald-700"
                      when "ineligible" then "bg-red-50 text-red-700"
                      when "ended" then "bg-amber-50 text-amber-700"
                      else "bg-gray-50 text-gray-700"
                    end %>
                    <span class="inline-flex items-center gap-1 rounded px-2 py-0.5 text-xs font-medium <%= classes %>"><%= relationship.status.humanize %></span>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @referral_relationships.empty? %>
        <div class="text-center py-12">
          <div class="text-gray-500 text-lg">No referral relationships found</div>
          <div class="text-gray-400 text-sm mt-2">Try adjusting your filters or attach a referral to a newly onboarded practice</div>
        </div>
      <% end %>
    </div>
  </div>
</div>
