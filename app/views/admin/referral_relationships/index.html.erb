<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div><h1 class="text-3xl font-bold text-gray-900">Referral Relationships</h1><p class="mt-2 text-gray-600">Monitor referred practices and commission windows.</p></div>
    <%= link_to "Export CSV", export_admin_referral_relationships_path, class: "inline-flex items-center rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
  </div>
  <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-gray-200"><thead class="bg-gray-50"><tr><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Partner</th><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Practice</th><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Signed Date</th><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Start Date</th><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">End Date</th><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Status</th></tr></thead><tbody class="divide-y divide-gray-200 bg-white"><% @relationships.each do |relationship| %><tr class="hover:bg-gray-50"><td class="px-6 py-4 text-sm font-medium text-gray-900"><%= relationship.referral_partner.full_name %></td><td class="px-6 py-4 text-sm font-medium text-gray-900"><%= link_to relationship.referred_practice_name, admin_referral_relationship_path(relationship), class: "text-indigo-600 hover:text-indigo-800" %></td><td class="px-6 py-4 text-sm text-gray-700"><%= relationship.contract_signed_date || "—" %></td><td class="px-6 py-4 text-sm text-gray-700"><%= relationship.commission_start_date || "—" %></td><td class="px-6 py-4 text-sm text-gray-700"><%= relationship.commission_end_date || "—" %></td><td class="px-6 py-4 text-sm text-gray-700"><%= relationship.status.humanize %></td></tr><% end %></tbody></table>
  </div>
</div>
