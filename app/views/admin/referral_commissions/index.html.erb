<div class="min-h-screen bg-gray-50 py-8">
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Referral Commission Queue</h1>
          <p class="mt-2 text-gray-600">Review monthly commissions before approval and payout</p>
        </div>
        <div>
          <%= link_to "Export CSV", export_admin_referral_commissions_path, class: "bg-white hover:bg-gray-50 text-gray-700 text-sm font-medium px-4 py-2 rounded-md border border-gray-300" %>
        </div>
      </div>
    </div>

    <%= render "shared/filters" %>

    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Partner</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Practice</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Month</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Eligible Revenue</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Commission Amount</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% if @referral_commissions.present? && @referral_commissions.any? %>
              <% @referral_commissions.each do |commission| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= commission.referral_partner.full_name %></td>
                  <td class="px-6 py-4 whitespace-nowrap"><%= link_to commission.referral_relationship.referred_practice_name, admin_referral_commission_path(commission), class: "text-sm font-medium text-indigo-600 hover:text-indigo-700" %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= commission.month.strftime("%b %Y") %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= number_to_currency(commission.eligible_revenue) %></td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= number_to_currency(commission.commission_amount) %></td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% classes = case commission.payout_status
                      when "paid" then "bg-emerald-50 text-emerald-700"
                      when "approved" then "bg-blue-50 text-blue-700"
                      when "denied" then "bg-red-50 text-red-700"
                      else "bg-gray-50 text-gray-700"
                    end %>
                    <span class="inline-flex items-center gap-1 rounded px-2 py-0.5 text-xs font-medium <%= classes %>"><%= commission.payout_status.humanize %></span>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @referral_commissions.empty? %>
        <div class="text-center py-12">
          <div class="text-gray-500 text-lg">No referral commissions found</div>
          <div class="text-gray-400 text-sm mt-2">Try adjusting your filters or generate commissions after month-end processing</div>
        </div>
      <% end %>
    </div>
  </div>
</div>
