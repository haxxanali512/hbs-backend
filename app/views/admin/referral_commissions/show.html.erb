<div class="w-full py-8 px-4 sm:px-6 lg:px-8">
  <div class="flex items-center justify-between mb-6 gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @referral_commission.referral_relationship.referred_practice_name %> - <%= @referral_commission.month.strftime("%b %Y") %></h1>
      <p class="mt-2 text-sm text-gray-600">Partner: <%= @referral_commission.referral_partner.full_name %></p>
    </div>
    <div class="flex gap-3">
      <% unless @referral_commission.approved? || @referral_commission.paid? %>
        <%= button_to "Approve", approve_admin_referral_commission_path(@referral_commission), method: :patch, data: { turbo: false }, class: "inline-flex items-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700" %>
      <% end %>
      <% unless @referral_commission.paid? %>
        <%= button_to "Mark Paid", mark_paid_admin_referral_commission_path(@referral_commission), method: :patch, data: { turbo: false }, class: "inline-flex items-center rounded-lg border border-indigo-200 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-50" %>
      <% end %>
    </div>
  </div>

  <%= form_with model: [ :admin, @referral_commission ], class: "rounded-2xl border border-gray-200 bg-white p-8 shadow-sm space-y-6", data: { turbo: false } do |f| %>
    <h3 class="text-base font-semibold text-gray-900">Commission Details</h3>
    <div class="grid gap-6 md:grid-cols-2">
      <div>
        <label class="block text-sm font-medium text-gray-700">Eligible Revenue</label>
        <%= f.number_field :eligible_revenue, step: :any, class: "mt-2 block h-11 w-full rounded-lg border border-gray-200 px-4 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Commission Percent</label>
        <%= f.number_field :commission_percent, step: :any, class: "mt-2 block h-11 w-full rounded-lg border border-gray-200 px-4 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Commission Amount</label>
        <%= f.number_field :commission_amount, step: :any, class: "mt-2 block h-11 w-full rounded-lg border border-gray-200 px-4 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Payout Status</label>
        <%= f.select :payout_status, ReferralCommission.payout_statuses.keys.map { |key| [key.humanize, key] }, {}, class: "mt-2 block h-11 w-full rounded-lg border border-gray-200 px-4 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Paid Date</label>
        <%= f.date_field :payout_date, class: "mt-2 block h-11 w-full rounded-lg border border-gray-200 px-4 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700">Notes</label>
      <%= f.text_area :notes, rows: 4, class: "mt-2 block w-full rounded-lg border border-gray-200 px-4 py-3 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div class="flex justify-end">
      <%= f.submit "Save Changes", class: "inline-flex items-center rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" %>
    </div>
  <% end %>
</div>
