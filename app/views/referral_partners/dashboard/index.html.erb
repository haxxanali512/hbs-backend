<div class="space-y-8">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Referral Partner Dashboard</h1>
    <p class="mt-2 text-gray-600">Track referral performance, eligibility, and payouts.</p>
  </div>

  <div class="grid gap-4 md:grid-cols-4">
    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm"><div class="text-sm text-gray-500">Total Referrals</div><div class="mt-2 text-3xl font-semibold text-gray-900"><%= @relationships.count %></div></div>
    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm"><div class="text-sm text-gray-500">Active Referrals</div><div class="mt-2 text-3xl font-semibold text-gray-900"><%= @relationships.active.count %></div></div>
    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm"><div class="text-sm text-gray-500">Lifetime Earnings</div><div class="mt-2 text-3xl font-semibold text-gray-900">$<%= @commissions.sum(:commission_amount).to_f.round(2) %></div></div>
    <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm"><div class="text-sm text-gray-500">Current Month Earnings</div><div class="mt-2 text-3xl font-semibold text-gray-900">$<%= @current_month_earnings.to_f.round(2) %></div></div>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <div class="flex items-center justify-between">
      <div>
        <h2 class="text-lg font-semibold text-gray-900">Referral Link</h2>
        <p class="mt-1 text-sm text-gray-600">Share your personalized onboarding link.</p>
      </div>
      <%= link_to "Manage Link", referral_partners_referral_links_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
    </div>
    <div class="mt-4 rounded-md border border-gray-200 bg-gray-50 p-4 text-sm text-gray-700"><%= @referral_partner.referral_url.presence || "No referral link has been assigned yet." %></div>
  </div>
</div>
