<div class="w-full py-8 px-4 sm:px-6 lg:px-8">
  <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Payout History</h1>
      <p class="mt-2 text-sm text-gray-600">Monthly commission history across all of your referred practices.</p>
    </div>
    <%= link_to export_referral_partner_payout_history_index_path, class: "inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 16V4m0 12l-4-4m4 4l4-4M4 20h16" />
      </svg>
      Export CSV
    <% end %>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-200 px-6 py-4">
      <h2 class="text-lg font-semibold text-gray-900">Monthly Commissions</h2>
      <p class="mt-1 text-sm text-gray-500">Newest payout periods appear first.</p>
    </div>

    <% if @commissions.any? %>
      <% columns = [
        { label: "Month", render: ->(commission) { commission.month.strftime("%b %Y") } },
        { label: "Practice Name", render: ->(commission) { commission.referral_relationship.referred_practice_name } },
        { label: "Eligible Revenue", render: ->(commission) { number_to_currency(commission.eligible_revenue) } },
        { label: "Commission Amount", render: ->(commission) { number_to_currency(commission.commission_amount) } },
        { label: "Status", render: ->(commission) { commission.payout_status.humanize } },
        { label: "Paid Date", render: ->(commission) { commission.payout_date&.strftime("%b %d, %Y") || "—" } }
      ] %>
      <%= render "shared/table", columns: columns, collection: @commissions %>
    <% else %>
      <div class="px-6 py-12 text-center">
        <h3 class="text-base font-medium text-gray-900">No payouts yet</h3>
        <p class="mt-2 text-sm text-gray-500">When monthly commissions are generated, they will appear here.</p>
      </div>
    <% end %>
  </div>
</div>
