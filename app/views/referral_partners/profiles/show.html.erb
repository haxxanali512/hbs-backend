<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Profile</h1>
      <p class="mt-2 text-gray-600">Manage your referral partner details.</p>
    </div>
    <%= link_to "Edit Profile", edit_referral_partners_profile_path, class: "inline-flex items-center rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <dl class="grid gap-6 md:grid-cols-2">
      <div><dt class="text-sm font-medium text-gray-500">Name</dt><dd class="mt-1 text-sm text-gray-900"><%= @referral_partner.full_name %></dd></div>
      <div><dt class="text-sm font-medium text-gray-500">Email</dt><dd class="mt-1 text-sm text-gray-900"><%= @referral_partner.email %></dd></div>
      <div><dt class="text-sm font-medium text-gray-500">Phone</dt><dd class="mt-1 text-sm text-gray-900"><%= @referral_partner.phone.presence || "—" %></dd></div>
      <div><dt class="text-sm font-medium text-gray-500">Tax Form Status</dt><dd class="mt-1 text-sm text-gray-900"><%= @referral_partner.tax_form_status.presence || "—" %></dd></div>
    </dl>
  </div>
</div>
