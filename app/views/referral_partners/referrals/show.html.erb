<div class="w-full py-8 px-4 sm:px-6 lg:px-8">
  <div class="mb-6 flex flex-col gap-3">
    <%= link_to referral_partner_referrals_path, class: "inline-flex items-center gap-2 text-sm font-medium text-blue-600 hover:text-blue-700" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Referrals
    <% end %>
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @relationship.referred_practice_name %></h1>
      <p class="mt-2 text-sm text-gray-600">Detailed commission and eligibility history for this referred practice.</p>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 xl:grid-cols-3">
    <div class="xl:col-span-1 space-y-6">
      <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
        <div class="border-b border-gray-200 px-6 py-4">
          <h2 class="text-lg font-semibold text-gray-900">Referral Details</h2>
        </div>
        <dl class="space-y-4 p-6 text-sm">
          <div class="flex items-start justify-between gap-4 border-b border-gray-100 pb-3">
            <dt class="text-gray-500">Contract Signed</dt>
            <dd class="text-right font-medium text-gray-900"><%= @relationship.contract_signed_date&.strftime("%b %d, %Y") || "—" %></dd>
          </div>
          <div class="flex items-start justify-between gap-4 border-b border-gray-100 pb-3">
            <dt class="text-gray-500">Commission Window</dt>
            <dd class="text-right font-medium text-gray-900"><%= [@relationship.commission_start_date, @relationship.commission_end_date].compact.map { |date| date.strftime("%b %d, %Y") }.join(" - ").presence || "—" %></dd>
          </div>
          <div class="flex items-start justify-between gap-4 border-b border-gray-100 pb-3">
            <dt class="text-gray-500">Current Status</dt>
            <dd class="text-right font-medium text-gray-900"><%= @relationship.status.humanize %></dd>
          </div>
          <div class="flex items-start justify-between gap-4 border-b border-gray-100 pb-3">
            <dt class="text-gray-500">Eligibility</dt>
            <dd class="text-right font-medium text-gray-900"><%= @relationship.eligibility_status.humanize %></dd>
          </div>
          <div class="flex items-start justify-between gap-4 border-b border-gray-100 pb-3">
            <dt class="text-gray-500">Revenue To Date</dt>
            <dd class="text-right font-medium text-gray-900"><%= number_to_currency(@relationship.total_revenue_to_date) %></dd>
          </div>
          <div class="flex items-start justify-between gap-4">
            <dt class="text-gray-500">Total Commissions</dt>
            <dd class="text-right font-medium text-gray-900"><%= number_to_currency(@relationship.total_commission_to_date) %></dd>
          </div>
        </dl>
      </div>

      <% if @relationship.ineligibility_reason.present? %>
        <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 shadow-sm">
          <h3 class="text-sm font-semibold text-amber-900">Ineligibility Reason</h3>
          <p class="mt-2 text-sm text-amber-800"><%= @relationship.ineligibility_reason %></p>
        </div>
      <% end %>
    </div>

    <div class="xl:col-span-2 rounded-lg border border-gray-200 bg-white shadow-sm">
      <div class="border-b border-gray-200 px-6 py-4">
        <h2 class="text-lg font-semibold text-gray-900">Monthly Commission History</h2>
        <p class="mt-1 text-sm text-gray-500">Monthly line items generated during the eligible referral window.</p>
      </div>

      <% if @commissions.any? %>
        <% columns = [
          { label: "Month", render: ->(commission) { commission.month.strftime("%b %Y") } },
          { label: "Eligible Revenue", render: ->(commission) { number_to_currency(commission.eligible_revenue) } },
          { label: "Commission", render: ->(commission) { number_to_currency(commission.commission_amount) } },
          { label: "Status", render: ->(commission) { commission.payout_status.humanize } },
          { label: "Paid Date", render: ->(commission) { commission.payout_date&.strftime("%b %d, %Y") || "—" } }
        ] %>
        <%= render "shared/table", columns: columns, collection: @commissions %>
      <% else %>
        <div class="px-6 py-12 text-center">
          <h3 class="text-base font-medium text-gray-900">No commission history yet</h3>
          <p class="mt-2 text-sm text-gray-500">Once commissions are generated for this referral, they will appear here.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
