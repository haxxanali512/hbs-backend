<style>
  .referral-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 400ms ease, transform 400ms ease;
  }

  .referral-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<div class="min-h-screen bg-gray-50 text-gray-900">
  <section class="border-b border-gray-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8 lg:py-18">
      <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div class="referral-reveal">
          <div class="mb-8 flex items-center gap-4">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl border border-gray-200 bg-white shadow-sm">
              <%= image_tag "HBS-logo-scaled (1).png", alt: "Holistic Business Solutions", class: "h-10 w-auto" %>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-blue-700">Holistic Business Solutions</p>
              <p class="mt-1 text-sm text-gray-500">Referral Partner Program</p>
            </div>
          </div>

          <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
            Refer practices you trust and track every eligible month from one place.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-gray-600">
            Approved partners receive a unique referral code, onboarding link, and a dedicated portal to follow referred practices, commission windows, and payout history.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <span class="inline-flex items-center rounded-full border border-blue-200 bg-blue-50 px-4 py-2 text-sm font-medium text-blue-700">12% of eligible collected billing revenue</span>
            <span class="inline-flex items-center rounded-full border border-gray-200 bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700">12-month commission window</span>
            <span class="inline-flex items-center rounded-full border border-gray-200 bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700">Monthly payout review</span>
          </div>

          <div class="mt-12 grid gap-4 sm:grid-cols-3">
            <div class="referral-reveal rounded-2xl border border-gray-200 bg-gray-50 p-5 shadow-sm">
              <div class="text-3xl font-bold text-gray-900">12%</div>
              <div class="mt-2 text-sm text-gray-600">Commission on eligible revenue collected for billing services.</div>
            </div>
            <div class="referral-reveal rounded-2xl border border-gray-200 bg-gray-50 p-5 shadow-sm">
              <div class="text-3xl font-bold text-gray-900">10</div>
              <div class="mt-2 text-sm text-gray-600">Business days after month-end for payout generation and review.</div>
            </div>
            <div class="referral-reveal rounded-2xl border border-gray-200 bg-gray-50 p-5 shadow-sm">
              <div class="text-3xl font-bold text-gray-900">1</div>
              <div class="mt-2 text-sm text-gray-600">Portal to view links, referral activity, eligibility, and payout history.</div>
            </div>
          </div>
        </div>

        <div class="referral-reveal">
          <div class="flex justify-center lg:justify-end">
            <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
              <%= image_tag "HBS-logo-scaled (1).png", alt: "Holistic Business Solutions", class: "h-40 w-auto sm:h-48" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-[1fr_0.95fr]">
      <div class="space-y-8">
        <div class="referral-reveal rounded-3xl border border-gray-200 bg-white p-8 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-widest text-blue-700">How It Works</p>
          <h2 class="mt-4 text-3xl font-bold tracking-tight text-gray-900">Simple approval flow, clear attribution, transparent payout tracking.</h2>
          <p class="mt-4 text-base leading-7 text-gray-600">
            The launch version is designed to keep referrals easy to submit and easy to monitor once approved.
          </p>

          <div class="mt-8 grid gap-4 sm:grid-cols-3">
            <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
              <div class="text-sm font-semibold text-gray-900">1. Apply</div>
              <p class="mt-3 text-sm leading-6 text-gray-600">Submit your name, email, phone number, and partner type for review.</p>
            </div>
            <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
              <div class="text-sm font-semibold text-gray-900">2. Get approved</div>
              <p class="mt-3 text-sm leading-6 text-gray-600">Approved partners receive a unique referral code, onboarding link, and portal access.</p>
            </div>
            <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5">
              <div class="text-sm font-semibold text-gray-900">3. Track activity</div>
              <p class="mt-3 text-sm leading-6 text-gray-600">Follow referral status, commission eligibility, and payout history in the partner dashboard.</p>
            </div>
          </div>
        </div>

        <div class="referral-reveal rounded-3xl border border-gray-200 bg-white p-8 shadow-sm">
          <h3 class="text-xl font-semibold text-gray-900">Program Terms</h3>
          <ul class="mt-6 space-y-4 text-sm leading-6 text-gray-600">
            <li class="flex gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-emerald-500"></span><span>Referral partners receive 12% of eligible collected billing revenue.</span></li>
            <li class="flex gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-emerald-500"></span><span>Software subscriptions, consulting, and non-billing services are excluded.</span></li>
            <li class="flex gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-emerald-500"></span><span>The commission window lasts 12 months starting on the first day of the month after contract execution.</span></li>
            <li class="flex gap-3"><span class="mt-1 h-2.5 w-2.5 rounded-full bg-emerald-500"></span><span>Payouts are generated monthly after collected revenue is confirmed and the client remains in good standing.</span></li>
          </ul>
        </div>

        <div class="referral-reveal rounded-3xl border border-blue-100 bg-blue-50 p-8 shadow-sm">
          <h3 class="text-xl font-semibold text-gray-900">What approved partners receive</h3>
          <div class="mt-6 grid gap-4">
            <div class="rounded-2xl border border-white bg-white p-5">
              <div class="text-sm font-semibold text-gray-900">Unique referral code</div>
              <p class="mt-2 text-sm text-gray-600">A dedicated code and referral link for onboarding attribution.</p>
            </div>
            <div class="rounded-2xl border border-white bg-white p-5">
              <div class="text-sm font-semibold text-gray-900">Partner dashboard</div>
              <p class="mt-2 text-sm text-gray-600">See referral activity, eligibility windows, current earnings, and payout history.</p>
            </div>
            <div class="rounded-2xl border border-white bg-white p-5">
              <div class="text-sm font-semibold text-gray-900">Clear monthly visibility</div>
              <p class="mt-2 text-sm text-gray-600">Track which referred practices are active, eligible, ended, or awaiting payout review.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="referral-reveal">
        <% if @submitted %>
          <div class="rounded-3xl border border-emerald-200 bg-white p-8 shadow-sm">
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h2 class="mt-6 text-2xl font-semibold text-gray-900">Application received</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Thank you for applying to the HBS Referral Partner Program. Our team will review your information and send onboarding details after approval.
            </p>
            <div class="mt-6 rounded-2xl border border-gray-200 bg-gray-50 p-4 text-sm text-gray-600">
              You can share this page with other potential partners at
              <span class="font-medium text-gray-900"><%= referral_root_url %></span>
            </div>
            <div class="mt-6">
              <%= link_to "Submit another application", referral_root_path, class: "inline-flex items-center rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-blue-700" %>
            </div>
          </div>
        <% else %>
          <div class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-2xl font-semibold text-gray-900">Apply to become a partner</h2>
                <p class="mt-2 text-sm text-gray-600">Tell us a bit about you and we’ll review your application.</p>
              </div>
              <div class="hidden h-12 w-12 items-center justify-center rounded-2xl border border-gray-200 bg-gray-50 text-gray-600 sm:flex">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422A12.083 12.083 0 0112 20.055a12.083 12.083 0 01-6.16-9.477L12 14z" />
                </svg>
              </div>
            </div>

            <%= form_with model: @referral_partner, url: referral_partner_apply_path, class: "mt-8 space-y-6", data: { turbo: false } do |f| %>
              <% if @referral_partner.errors.any? %>
                <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                  <ul class="space-y-1">
                    <% @referral_partner.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              <% end %>

              <div>
                <label class="block text-sm font-medium text-gray-700">Full Name</label>
                <%= text_field_tag "referral_partner[full_name]",
                  [@referral_partner.first_name, @referral_partner.last_name].compact.join(" ").strip,
                  class: "mt-2 block h-12 w-full rounded-xl border border-gray-200 bg-white px-4 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:ring-blue-500",
                  placeholder: "Your full name" %>
              </div>

              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label class="block text-sm font-medium text-gray-700">Email</label>
                  <%= f.email_field :email,
                    class: "mt-2 block h-12 w-full rounded-xl border border-gray-200 bg-white px-4 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:ring-blue-500",
                    placeholder: "name@example.com" %>
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-700">Phone</label>
                  <%= f.telephone_field :phone,
                    class: "mt-2 block h-12 w-full rounded-xl border border-gray-200 bg-white px-4 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:ring-blue-500",
                    placeholder: "(555) 123-4567" %>
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700">Partner Type</label>
                <%= f.select :partner_type,
                  ReferralPartner.partner_types.keys.map { |key| [key.humanize, key] },
                  { prompt: "Select partner type" },
                  class: "mt-2 block h-12 w-full rounded-xl border border-gray-200 bg-white px-4 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
              </div>

              <div class="rounded-2xl border border-gray-200 bg-gray-50 p-4 text-sm text-gray-600">
                By applying, you’re asking to be reviewed for referral partner eligibility. Approved partners receive a unique referral code and onboarding link after review.
              </div>

              <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                <div class="text-xs leading-5 text-gray-500">
                  Commission eligibility begins on the first day of the month following the referred client’s executed agreement date.
                </div>
                <%= f.submit "Submit Application", class: "inline-flex items-center justify-center rounded-xl bg-blue-600 px-5 py-3 text-sm font-medium text-white shadow-sm hover:bg-blue-700" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </section>
</div>

<script>
  (function() {
    function initializeReferralLandingReveals() {
      const elements = document.querySelectorAll(".referral-reveal");
      if (!elements.length || typeof IntersectionObserver === "undefined") {
        elements.forEach((element) => element.classList.add("is-visible"));
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });

      elements.forEach((element, index) => {
        element.style.transitionDelay = `${Math.min(index * 50, 220)}ms`;
        observer.observe(element);
      });
    }

    document.addEventListener("DOMContentLoaded", initializeReferralLandingReveals);
    document.addEventListener("turbo:load", initializeReferralLandingReveals);
  })();
</script>
